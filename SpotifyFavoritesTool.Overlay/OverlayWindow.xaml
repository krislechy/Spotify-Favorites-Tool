<Window x:Class="SpotifyFavoritesTool.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SpotifyFavoritesTool;assembly=SpotifyFavoritesTool.Models"
        xmlns:ui="clr-namespace:SpotifyFavoritesTool.UI;assembly=SpotifyFavoritesTool.UI"
        Width="462"
        Height="150"
        MinWidth="390"
        MinHeight="132"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        KeyboardNavigation.TabNavigation="None"
        KeyboardNavigation.ControlTabNavigation="None"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="OverlayIconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="ui:RippleEffectBehavior.IsEnabled" Value="True" />
            <Setter Property="ui:RippleEffectBehavior.RippleBrush" Value="#1ED760" />
            <Setter Property="ui:RippleEffectBehavior.PressedOpacity" Value="0.24" />
            <Setter Property="ui:RippleEffectBehavior.DurationMilliseconds" Value="420" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" />
                            <Canvas x:Name="RippleHost"
                                    ClipToBounds="True"
                                    IsHitTestVisible="False">
                                <Canvas.OpacityMask>
                                    <VisualBrush Visual="{Binding ElementName=Root}" />
                                </Canvas.OpacityMask>
                            </Canvas>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#203A29" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1ED760" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportButton" BasedOn="{StaticResource OverlayIconButton}" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="HistoryPlayButton" BasedOn="{StaticResource OverlayIconButton}" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>

        <Style x:Key="ArtworkFrameStyle" TargetType="Border">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="64" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#202824" />
            <Setter Property="BorderBrush" Value="#334139" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="0"
                                      ShadowDepth="0"
                                      Opacity="0"
                                      Color="#1ED760" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#668DE6B1" />
                    <Setter Property="Background" Value="#203228" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="24"
                                              ShadowDepth="0"
                                              Opacity="0.46"
                                              Color="#5AF0A0" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ui:LiquidHoverBorder x:Name="OverlayRoot"
                             Margin="7"
                             Padding="12"
                             CornerRadius="12"
                             BaseColor="#101512"
                             SurfaceOpacity="1"
                             BorderBrush="#365142"
                             BorderThickness="1"
                             SnapsToDevicePixels="True"
                             MouseLeftButtonDown="OverlayRoot_MouseLeftButtonDown">
        <ui:LiquidHoverBorder.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.35"
                              Color="#000000" />
        </ui:LiquidHoverBorder.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
                <RowDefinition x:Name="HistoryRow" Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="74" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="42" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ArtworkFrame"
                    Style="{StaticResource ArtworkFrameStyle}"
                    ToolTipService.InitialShowDelay="80"
                    ToolTipService.BetweenShowDelay="0"
                    ToolTipService.ShowDuration="60000">
                <Border.ToolTip>
                    <ToolTip x:Name="AlbumArtPreviewToolTip"
                             Placement="Mouse"
                             IsEnabled="False">
                        <Border x:Name="AlbumArtPreviewFrame"
                                Width="320"
                                Height="320"
                                CornerRadius="10"
                                Background="#101512"
                                BorderBrush="#365142"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.OpacityMask>
                                    <VisualBrush>
                                        <VisualBrush.Visual>
                                            <Border Width="320"
                                                    Height="320"
                                                    Background="Black"
                                                    CornerRadius="10" />
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Grid.OpacityMask>
                                <Image x:Name="AlbumArtPreview"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Grid>
                        </Border>
                    </ToolTip>
                </Border.ToolTip>
                <Border CornerRadius="8"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.OpacityMask>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Border Width="64"
                                            Height="64"
                                            Background="Black"
                                            CornerRadius="8" />
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Grid.OpacityMask>
                        <Image x:Name="AlbumArt"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               ImageFailed="AlbumArt_ImageFailed" />
                        <Border x:Name="ArtworkHoverWash"
                                CornerRadius="8"
                                Opacity="0"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <RadialGradientBrush Center="0.34,0.22"
                                                     GradientOrigin="0.28,0.18"
                                                     RadiusX="0.78"
                                                     RadiusY="0.78">
                                    <GradientStop Color="#661ED760" Offset="0" />
                                    <GradientStop Color="#338DE6B1" Offset="0.42" />
                                    <GradientStop Color="#00000000" Offset="1" />
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border x:Name="ArtworkInnerGlow"
                                BorderBrush="#708DE6B1"
                                BorderThickness="1"
                                CornerRadius="8"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <TextBlock x:Name="AlbumPlaceholder"
                                   Text="SP"
                                   Foreground="#6F7D74"
                                   FontWeight="Bold"
                                   FontSize="17"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ArtworkHoverWash"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetName="ArtworkInnerGlow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.16" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ArtworkHoverWash"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.24" />
                                <DoubleAnimation Storyboard.TargetName="ArtworkInnerGlow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.24" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>

            <Grid Grid.Column="1"
                  Margin="0,2,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="27" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="TrackTitle"
                           Foreground="#F7FAF8"
                           FontSize="15"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ArtistText"
                           Grid.Row="1"
                           Foreground="#B9C4BE"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <Button x:Name="FavoriteButton"
                    Grid.Column="2"
                    Style="{StaticResource OverlayIconButton}"
                    Content="♡"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="FavoriteButton_Click"
                    ToolTip="Переключить Избранное для текущего трека" />

            <StackPanel Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom">
                <Button x:Name="PreviousButton"
                        Style="{StaticResource TransportButton}"
                        Content="⏮"
                        Click="PreviousButton_Click"
                        ToolTip="Предыдущий трек" />
                <Button x:Name="PlayPauseButton"
                        Style="{StaticResource TransportButton}"
                        Click="PlayPauseButton_Click"
                        ToolTip="Пауза / воспроизведение">
                    <Canvas Width="16"
                            Height="16"
                            IsHitTestVisible="False">
                        <Path x:Name="PlayGlyph"
                              Data="M 4,3 L 13,8 L 4,13 Z"
                              Fill="#F4F8F5"
                              Visibility="Collapsed" />
                        <Rectangle x:Name="PauseGlyphLeft"
                                   Width="3.2"
                                   Height="10"
                                   RadiusX="1"
                                   RadiusY="1"
                                   Fill="#F4F8F5"
                                   Canvas.Left="4"
                                   Canvas.Top="3" />
                        <Rectangle x:Name="PauseGlyphRight"
                                   Width="3.2"
                                   Height="10"
                                   RadiusX="1"
                                   RadiusY="1"
                                   Fill="#F4F8F5"
                                   Canvas.Left="9"
                                   Canvas.Top="3" />
                    </Canvas>
                </Button>
                <Button x:Name="NextButton"
                        Style="{StaticResource TransportButton}"
                        Content="⏭"
                        Click="NextButton_Click"
                        ToolTip="Следующий трек" />
                <Button x:Name="HistoryToggleButton"
                        Style="{StaticResource TransportButton}"
                        Margin="0,0,8,0"
                        Click="HistoryToggleButton_Click"
                        ToolTip="Показать воспроизводившиеся ранее треки">
                    <Canvas Width="16"
                            Height="16"
                            IsHitTestVisible="False">
                        <Path Data="M 3,4 L 13,4 M 3,8 L 13,8 M 3,12 L 13,12"
                              Stroke="#F4F8F5"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Canvas>
                </Button>
                <Button x:Name="KaraokeToggleButton"
                        Style="{StaticResource TransportButton}"
                        Margin="0"
                        Click="KaraokeToggleButton_Click"
                        ToolTip="Показать караоке">
                    <Canvas Width="16"
                            Height="16"
                            IsHitTestVisible="False">
                        <Path Data="M 8,1.8 C 6.4,1.8 5.3,3 5.3,4.7 L 5.3,8.2 C 5.3,9.9 6.4,11.1 8,11.1 C 9.6,11.1 10.7,9.9 10.7,8.2 L 10.7,4.7 C 10.7,3 9.6,1.8 8,1.8 Z"
                              Fill="#F4F8F5" />
                        <Path Data="M 3.5,7.8 C 3.5,10.5 5.3,12.5 8,12.5 C 10.7,12.5 12.5,10.5 12.5,7.8 M 8,12.5 L 8,15 M 5.6,15 L 10.4,15"
                              Stroke="#8DE6B1"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Canvas>
                </Button>
            </StackPanel>

            <ui:LiquidHoverBorder x:Name="HistoryPanel"
                                     Grid.Row="2"
                                     Grid.ColumnSpan="3"
                                     Margin="0,12,0,0"
                                     Padding="10"
                                     Height="276"
                                     Visibility="Collapsed"
                                     CornerRadius="10"
                                     BaseColor="#141B17"
                                     BorderBrush="#32483C"
                                     BorderThickness="1"
                                     IsLiquidEnabled="False"
                                     SurfaceOpacity="0.20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="HistoryTitleText"
                               Text="Текущий плейлист"
                               Foreground="#F4F8F5"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,0,0,8" />
                    <ListBox x:Name="CachedTracksList"
                             Grid.Row="1"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.CanContentScroll="False"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="IsTabStop" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Grid x:Name="SectionHeader"
                                          Margin="0,2,0,7"
                                          Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Height="1"
                                                VerticalAlignment="Center"
                                                Background="#223E4F43" />
                                        <TextBlock x:Name="SectionHeaderText"
                                                   Grid.Column="1"
                                                   Margin="10,0"
                                                   Foreground="#8DE6B1"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Text="Раздел" />
                                        <Border Grid.Column="2"
                                                Height="1"
                                                VerticalAlignment="Center"
                                                Background="#223E4F43" />
                                    </Grid>

                                    <Border x:Name="HistoryItemRoot"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                        <Border x:Name="HistoryCover"
                                                Width="34"
                                                Height="34"
                                                Margin="0,0,8,0"
                                                CornerRadius="6"
                                                Background="#202824"
                                                ClipToBounds="True"
                                                Visibility="Visible">
                                            <Image Source="{Binding Track.AlbumImageUrl}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>

                                        <Grid Grid.Column="1"
                                              VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="16" />
                                                <RowDefinition Height="14" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock x:Name="HistoryTrackLine"
                                                       Text="{Binding Track.Name}"
                                                       Foreground="#F4F8F5"
                                                       FontSize="11.5"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock x:Name="HistoryArtistLine"
                                                       Grid.Row="1"
                                                       Text="{Binding Track.Artists}"
                                                       Foreground="#9FAAA3"
                                                       FontSize="10"
                                                       TextTrimming="CharacterEllipsis" />

                                            <StackPanel x:Name="NowPlayingEqualizer"
                                                        Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Width="22"
                                                        Height="14"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="Collapsed">
                                                <StackPanel.Resources>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Width" Value="3" />
                                                        <Setter Property="RadiusX" Value="1.4" />
                                                        <Setter Property="RadiusY" Value="1.4" />
                                                        <Setter Property="Fill" Value="#8DE6B1" />
                                                        <Setter Property="VerticalAlignment" Value="Bottom" />
                                                        <Setter Property="Margin" Value="0,0,2,0" />
                                                    </Style>
                                                </StackPanel.Resources>
                                                <Rectangle Height="5">
                                                    <Rectangle.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                                     From="5"
                                                                                     To="13"
                                                                                     Duration="0:0:0.34" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Rectangle.Triggers>
                                                </Rectangle>
                                                <Rectangle Height="11">
                                                    <Rectangle.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                                     From="11"
                                                                                     To="4"
                                                                                     BeginTime="0:0:0.08"
                                                                                     Duration="0:0:0.42" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Rectangle.Triggers>
                                                </Rectangle>
                                                <Rectangle Height="7">
                                                    <Rectangle.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                                     From="7"
                                                                                     To="14"
                                                                                     BeginTime="0:0:0.14"
                                                                                     Duration="0:0:0.30" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Rectangle.Triggers>
                                                </Rectangle>
                                                <Rectangle Height="12" Margin="0">
                                                    <Rectangle.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                                     From="12"
                                                                                     To="5"
                                                                                     BeginTime="0:0:0.20"
                                                                                     Duration="0:0:0.38" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Rectangle.Triggers>
                                                </Rectangle>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel x:Name="HistoryActions"
                                                    Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Visibility="Collapsed">
                                            <Button Style="{StaticResource HistoryPlayButton}"
                                                    Tag="{Binding Track}"
                                                    Click="CachedTrackPlayButton_Click"
                                                    ToolTip="Запустить этот трек">
                                                <Canvas Width="14"
                                                        Height="14"
                                                        IsHitTestVisible="False">
                                                    <Path Data="M 4,2.5 L 12,7 L 4,11.5 Z"
                                                          Fill="#F4F8F5" />
                                                </Canvas>
                                            </Button>
                                            <Button Style="{StaticResource HistoryPlayButton}"
                                                    Tag="{Binding Track}"
                                                    Content="{Binding Track.FavoriteGlyph}"
                                                    Click="CachedTrackFavoriteButton_Click"
                                                    ToolTip="Переключить Избранное" />
                                        </StackPanel>

                                            <Grid x:Name="HistoryMeta"
                                                  Grid.Column="2"
                                                  Width="46"
                                                  Margin="8,0,0,0"
                                                  VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="15" />
                                                    <RowDefinition Height="16" />
                                                </Grid.RowDefinitions>
                                                <TextBlock x:Name="HistoryDuration"
                                                           Text="{Binding Track.DurationText}"
                                                           Foreground="#7F8D84"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center" />
                                                <TextBlock x:Name="HistoryFavoriteGlyph"
                                                           Grid.Row="1"
                                                           Text="{Binding Track.FavoriteGlyph}"
                                                           Foreground="#8DE6B1"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ShowSectionHeader}" Value="True">
                                        <Setter TargetName="SectionHeader" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Section}" Value="{x:Static local:OverlayTrackSection.Queue}">
                                        <Setter TargetName="SectionHeaderText" Property="Text" Value="Далее" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Section}" Value="{x:Static local:OverlayTrackSection.NowPlaying}">
                                        <Setter TargetName="SectionHeaderText" Property="Text" Value="Сейчас играет" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Section}" Value="{x:Static local:OverlayTrackSection.RecentlyPlayed}">
                                        <Setter TargetName="SectionHeaderText" Property="Text" Value="Сыграно недавно" />
                                    </DataTrigger>
                                    <Trigger SourceName="HistoryItemRoot" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="HistoryItemRoot" Property="Background" Value="#40202A24" />
                                        <Setter TargetName="HistoryItemRoot" Property="BorderBrush" Value="#314638" />
                                        <Setter TargetName="HistoryActions" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="HistoryMeta" Property="Visibility" Value="Collapsed" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding Track.IsPlaying}" Value="True">
                                        <Setter TargetName="NowPlayingEqualizer" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Track.IsPlaying}" Value="False">
                                        <Setter TargetName="HistoryItemRoot" Property="Opacity" Value="0.58" />
                                        <Setter TargetName="HistoryTrackLine" Property="Foreground" Value="#A3AEA7" />
                                        <Setter TargetName="HistoryArtistLine" Property="Foreground" Value="#7F8D84" />
                                        <Setter TargetName="HistoryCover" Property="Opacity" Value="0.56" />
                                        <Setter TargetName="HistoryFavoriteGlyph" Property="Foreground" Value="#7F8D84" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="TrackListEmptyText"
                               Grid.Row="1"
                               Text="Spotify не отдал плейлист для текущего трека."
                               Foreground="#7F8D84"
                               FontSize="12"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Visibility="Collapsed" />

                    <Border Grid.Row="1"
                            Height="44"
                            VerticalAlignment="Bottom"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="0,1">
                                <GradientStop Color="#00141B17"
                                              Offset="0" />
                                <GradientStop Color="#66141B17"
                                              Offset="0.56" />
                                <GradientStop Color="#D8141B17"
                                              Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </ui:LiquidHoverBorder>

            <ui:LiquidHoverBorder x:Name="KaraokePanel"
                                  Grid.Row="2"
                                  Grid.ColumnSpan="3"
                                  Margin="0,12,0,0"
                                  Padding="10"
                                  Height="276"
                                  Visibility="Collapsed"
                                  CornerRadius="10"
                                  BaseColor="#141B17"
                                  BorderBrush="#32483C"
                                  BorderThickness="1"
                                  IsLiquidEnabled="False"
                                  SurfaceOpacity="0.20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Караоке"
                                   Foreground="#F4F8F5"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="KaraokeStatusText"
                                   Grid.Column="1"
                                   Foreground="#8DE6B1"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <ListBox x:Name="KaraokeLyricsList"
                             Grid.Row="1"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#D7E4DC"
                             IsTabStop="False"
                             ScrollViewer.CanContentScroll="False"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="IsTabStop" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="KaraokeLineRoot"
                                        Padding="10,7"
                                        CornerRadius="8"
                                        Background="Transparent">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TimeText}"
                                                   Foreground="#6F7D74"
                                                   FontFamily="Consolas"
                                                   FontSize="10"
                                                   VerticalAlignment="Center" />
                                        <TextBlock x:Name="KaraokeLineText"
                                                   Grid.Column="1"
                                                   Text="{Binding Text}"
                                                   Foreground="#B9C4BE"
                                                   FontSize="12.5"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                        <Setter TargetName="KaraokeLineRoot" Property="Background" Value="#3020362B" />
                                        <Setter TargetName="KaraokeLineText" Property="Foreground" Value="#F7FAF8" />
                                        <Setter TargetName="KaraokeLineText" Property="FontSize" Value="15.5" />
                                        <Setter TargetName="KaraokeLineText" Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="PlainLyricsText"
                               Grid.Row="1"
                               Visibility="Collapsed"
                               Foreground="#D7E4DC"
                               FontSize="12.5"
                               LineHeight="19"
                               TextWrapping="Wrap" />
                </Grid>
            </ui:LiquidHoverBorder>
        </Grid>
    </ui:LiquidHoverBorder>
</Window>
