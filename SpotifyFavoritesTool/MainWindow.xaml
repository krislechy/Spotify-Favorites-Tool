<Window x:Class="SpotifyFavoritesTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SpotifyFavoritesTool.UI;assembly=SpotifyFavoritesTool.UI"
        Title="Spotify Favorites Tool"
        Width="720"
        Height="540"
        MinWidth="540"
        MinHeight="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyboardNavigation.TabNavigation="None"
        KeyboardNavigation.ControlTabNavigation="None"
        SourceInitialized="Window_SourceInitialized">
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="ui:RippleEffectBehavior.IsEnabled" Value="True" />
            <Setter Property="ui:RippleEffectBehavior.RippleBrush" Value="#1ED760" />
            <Setter Property="ui:RippleEffectBehavior.PressedOpacity" Value="0.24" />
            <Setter Property="ui:RippleEffectBehavior.DurationMilliseconds" Value="460" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" />
                            <Canvas x:Name="RippleHost"
                                    ClipToBounds="True"
                                    IsHitTestVisible="False">
                                <Canvas.OpacityMask>
                                    <VisualBrush Visual="{Binding ElementName=Root}" />
                                </Canvas.OpacityMask>
                            </Canvas>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#203A29" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1ED760" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleButton" BasedOn="{StaticResource IconButton}" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ActionButton" BasedOn="{StaticResource IconButton}" TargetType="Button">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="MinWidth" Value="148" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="LogExpanderToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Viewbox x:Name="Arrow"
                                     Width="10"
                                     Height="10"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Path Data="M 1,3 L 5,7 L 9,3"
                                      Stroke="#8DE6B1"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1ED760" />
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.28" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogExpander" TargetType="Expander">
            <Setter Property="Foreground" Value="#D7E4DC" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="HeaderToggle"
                                              Style="{StaticResource LogExpanderToggle}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              Visibility="Collapsed" />
                                <ContentPresenter x:Name="HeaderContent"
                                                  Grid.Column="0"
                                                  Grid.ColumnSpan="2"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center" />
                            </Grid>
                            <Border x:Name="ContentRoot"
                                    Grid.Row="1"
                                    Margin="26,5,0,3"
                                    Padding="10,8"
                                    CornerRadius="8"
                                    Background="#221B241F"
                                    BorderBrush="#26362D"
                                    BorderThickness="1"
                                    Visibility="Collapsed">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentRoot" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <DataTrigger Binding="{Binding HasDetails}" Value="True">
                                <Setter TargetName="HeaderToggle" Property="Visibility" Value="Visible" />
                                <Setter TargetName="HeaderContent" Property="Grid.Column" Value="1" />
                                <Setter TargetName="HeaderContent" Property="Grid.ColumnSpan" Value="1" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ui:LiquidHoverBorder Margin="8"
                             CornerRadius="12"
                             BaseColor="#101512"
                             SurfaceOpacity="1"
                             BorderBrush="#2A3A31"
                             BorderThickness="1"
                             SnapsToDevicePixels="True">
        <ui:LiquidHoverBorder.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.28"
                              Color="#000000" />
        </ui:LiquidHoverBorder.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Margin="10,8,10,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="28"
                        Height="28"
                        CornerRadius="7"
                        Background="#1ED760">
                    <TextBlock Text="♥"
                               Foreground="#0F1511"
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Spotify Favorites Tool"
                               Foreground="#F4F8F5"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Горячая клавиша для текущего трека"
                               Foreground="#7F8D84"
                               FontSize="10" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleButton}"
                            Content="⚙"
                            Click="SettingsButton_Click"
                            ToolTip="Настройки" />
                    <Button Style="{StaticResource TitleButton}"
                            Content="─"
                            Click="MinimizeButton_Click"
                            ToolTip="Свернуть" />
                    <Button Style="{StaticResource TitleButton}"
                            Content="×"
                            Margin="0"
                            Click="CloseToTrayButton_Click"
                            ToolTip="Закрыть в трей" />
                </StackPanel>
            </Grid>

            <ui:LiquidHoverBorder Grid.Row="1"
                                     Margin="12,10,12,12"
                                     Padding="16"
                                     CornerRadius="10"
                                     BaseColor="#141B17"
                                     IsLiquidEnabled="False"
                                     SurfaceOpacity="0.20"
                                     BorderBrush="#25342C"
                                     BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Горячие клавиши Spotify"
                               Foreground="#D7E4DC"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />

                    <ui:LiquidHoverBorder Grid.Row="1"
                                             Margin="0,14,0,0"
                                             Padding="12"
                                             CornerRadius="8"
                                             BaseColor="#18201B"
                                             IsLiquidEnabled="False"
                                             SurfaceOpacity="0.20"
                                             BorderBrush="#28362E"
                                             BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="HotkeyText"
                                       Foreground="#8DE6B1"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="StatusText"
                                       Margin="0,8,0,0"
                                       Foreground="#D7E4DC"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ui:LiquidHoverBorder>

                    <StackPanel Grid.Row="2"
                                Margin="0,14,0,0"
                                Orientation="Horizontal">
                        <Button x:Name="OverlayButton"
                                Style="{StaticResource ActionButton}"
                                Content="Запустить Overlay"
                                Click="OverlayButton_Click"
                                ToolTip="Открыть отдельное окно оверлея поверх окон" />
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Журнал действий"
                                       DockPanel.Dock="Left"
                                       Foreground="#F4F8F5"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="последние 50"
                                       HorizontalAlignment="Right"
                                       Foreground="#7F8D84"
                                       FontSize="11" />
                        </DockPanel>

                        <ui:LiquidHoverBorder Grid.Row="1"
                                                 CornerRadius="8"
                                                  BaseColor="#111714"
                                                  IsLiquidEnabled="False"
                                                  SurfaceOpacity="0.20"
                                                 BorderBrush="#25342C"
                                                 BorderThickness="1">
                            <ListBox x:Name="ActivityLogList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#D7E4DC"
                                     IsTabStop="False"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <Setter Property="IsTabStop" Value="False" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Margin="10,5"
                                                  Style="{StaticResource LogExpander}">
                                            <Expander.Header>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="64" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding TimeText}"
                                                               Foreground="#8DE6B1"
                                                               FontFamily="Consolas"
                                                               FontSize="11" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               Foreground="#D7E4DC"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </Expander.Header>
                                            <TextBlock Text="{Binding Details}"
                                                       Foreground="#B9C4BE"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </Expander>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ui:LiquidHoverBorder>
                    </Grid>
                </Grid>
            </ui:LiquidHoverBorder>
        </Grid>
    </ui:LiquidHoverBorder>
</Window>
