<Window x:Class="SpotifyFavoritesTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SpotifyFavoritesTool"
        Title="Spotify Favorites Tool"
        Width="720"
        Height="540"
        MinWidth="540"
        MinHeight="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="True"
        Background="Transparent"
        Opacity="0.80"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyboardNavigation.TabNavigation="None"
        KeyboardNavigation.ControlTabNavigation="None"
        SourceInitialized="Window_SourceInitialized">
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="local:RippleEffectBehavior.IsEnabled" Value="True" />
            <Setter Property="local:RippleEffectBehavior.RippleBrush" Value="#1ED760" />
            <Setter Property="local:RippleEffectBehavior.PressedOpacity" Value="0.24" />
            <Setter Property="local:RippleEffectBehavior.DurationMilliseconds" Value="460" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" />
                            <Canvas x:Name="RippleHost"
                                    ClipToBounds="True"
                                    IsHitTestVisible="False">
                                <Canvas.OpacityMask>
                                    <VisualBrush Visual="{Binding ElementName=Root}" />
                                </Canvas.OpacityMask>
                            </Canvas>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#203A29" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1ED760" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleButton" BasedOn="{StaticResource IconButton}" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ActionButton" BasedOn="{StaticResource IconButton}" TargetType="Button">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="MinWidth" Value="148" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <local:LiquidHoverBorder Margin="8"
                             CornerRadius="12"
                             BaseColor="#101512"
                             SurfaceOpacity="0.20"
                             BorderBrush="#2A3A31"
                             BorderThickness="1"
                             SnapsToDevicePixels="True">
        <local:LiquidHoverBorder.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.28"
                              Color="#000000" />
        </local:LiquidHoverBorder.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Margin="10,8,10,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="28"
                        Height="28"
                        CornerRadius="7"
                        Background="#1ED760">
                    <TextBlock Text="♥"
                               Foreground="#0F1511"
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Spotify Favorites Tool"
                               Foreground="#F4F8F5"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Горячая клавиша для текущего трека"
                               Foreground="#7F8D84"
                               FontSize="10" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleButton}"
                            Content="⚙"
                            Click="SettingsButton_Click"
                            ToolTip="Настройки" />
                    <Button Style="{StaticResource TitleButton}"
                            Content="─"
                            Click="MinimizeButton_Click"
                            ToolTip="Свернуть" />
                    <Button Style="{StaticResource TitleButton}"
                            Content="×"
                            Margin="0"
                            Click="CloseToTrayButton_Click"
                            ToolTip="Закрыть в трей" />
                </StackPanel>
            </Grid>

            <local:LiquidHoverBorder Grid.Row="1"
                                     Margin="12,10,12,12"
                                     Padding="16"
                                     CornerRadius="10"
                                     BaseColor="#141B17"
                                     IsLiquidEnabled="False"
                                     SurfaceOpacity="0.20"
                                     BorderBrush="#25342C"
                                     BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Одна клавиша для добавления и удаления текущего трека из Избранного"
                               Foreground="#D7E4DC"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />

                    <local:LiquidHoverBorder Grid.Row="1"
                                             Margin="0,14,0,0"
                                             Padding="12"
                                             CornerRadius="8"
                                             BaseColor="#18201B"
                                             IsLiquidEnabled="False"
                                             SurfaceOpacity="0.20"
                                             BorderBrush="#28362E"
                                             BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="HotkeyText"
                                       Foreground="#8DE6B1"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="StatusText"
                                       Margin="0,8,0,0"
                                       Foreground="#D7E4DC"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </local:LiquidHoverBorder>

                    <StackPanel Grid.Row="2"
                                Margin="0,14,0,0"
                                Orientation="Horizontal">
                        <Button x:Name="OverlayButton"
                                Style="{StaticResource ActionButton}"
                                Content="Запустить Overlay"
                                Click="OverlayButton_Click"
                                ToolTip="Открыть отдельное окно оверлея поверх окон" />
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Журнал действий"
                                       DockPanel.Dock="Left"
                                       Foreground="#F4F8F5"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="последние 50"
                                       HorizontalAlignment="Right"
                                       Foreground="#7F8D84"
                                       FontSize="11" />
                        </DockPanel>

                        <local:LiquidHoverBorder Grid.Row="1"
                                                 CornerRadius="8"
                                                  BaseColor="#111714"
                                                  IsLiquidEnabled="False"
                                                  SurfaceOpacity="0.20"
                                                 BorderBrush="#25342C"
                                                 BorderThickness="1">
                            <ListBox x:Name="ActivityLogList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#D7E4DC"
                                     IsTabStop="False"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <Setter Property="IsTabStop" Value="False" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="10,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TimeText}"
                                                       Foreground="#8DE6B1"
                                                       FontFamily="Consolas"
                                                       FontSize="11" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Message}"
                                                       Foreground="#D7E4DC"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </local:LiquidHoverBorder>
                    </Grid>
                </Grid>
            </local:LiquidHoverBorder>
        </Grid>
    </local:LiquidHoverBorder>
</Window>
