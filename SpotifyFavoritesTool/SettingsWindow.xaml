<Window x:Class="SpotifyFavoritesTool.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SpotifyFavoritesTool.UI;assembly=SpotifyFavoritesTool.UI"
        Title="Настройки Избранного"
        Width="620"
        Height="680"
        MinWidth="540"
        MinHeight="440"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="#F4F8F5"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyboardNavigation.TabNavigation="None"
        KeyboardNavigation.ControlTabNavigation="None">
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="ui:RippleEffectBehavior.IsEnabled" Value="True" />
            <Setter Property="ui:RippleEffectBehavior.RippleBrush" Value="#1ED760" />
            <Setter Property="ui:RippleEffectBehavior.PressedOpacity" Value="0.24" />
            <Setter Property="ui:RippleEffectBehavior.DurationMilliseconds" Value="460" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" />
                            <Canvas x:Name="RippleHost"
                                    ClipToBounds="True"
                                    IsHitTestVisible="False">
                                <Canvas.OpacityMask>
                                    <VisualBrush Visual="{Binding ElementName=Root}" />
                                </Canvas.OpacityMask>
                            </Canvas>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#203A29" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1ED760" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleButton" BasedOn="{StaticResource IconButton}" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ButtonIconPath" TargetType="Path">
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="StrokeThickness" Value="1.7" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="CaretBrush" Value="#1ED760" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>

        <Style x:Key="SettingsButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="ui:RippleEffectBehavior.IsEnabled" Value="True" />
            <Setter Property="ui:RippleEffectBehavior.RippleBrush" Value="#1ED760" />
            <Setter Property="ui:RippleEffectBehavior.PressedOpacity" Value="0.22" />
            <Setter Property="ui:RippleEffectBehavior.DurationMilliseconds" Value="520" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8" />
                            <Canvas x:Name="RippleHost"
                                    ClipToBounds="True"
                                    IsHitTestVisible="False">
                                <Canvas.OpacityMask>
                                    <VisualBrush Visual="{Binding ElementName=Root}" />
                                </Canvas.OpacityMask>
                            </Canvas>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#203A29" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1ED760" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ui:LiquidHoverBorder Margin="8"
                             CornerRadius="12"
                             BaseColor="#101512"
                             SurfaceOpacity="1"
                             BorderBrush="#2A3A31"
                             BorderThickness="1"
                             SnapsToDevicePixels="True">
        <ui:LiquidHoverBorder.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.28"
                              Color="#000000" />
        </ui:LiquidHoverBorder.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Margin="10,8,10,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="28"
                        Height="28"
                        CornerRadius="7"
                        Background="#1ED760">
                    <TextBlock Text="♥"
                               Foreground="#0F1511"
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Настройки Избранного"
                               Foreground="#F4F8F5"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Spotify, горячие клавиши и авторизация"
                               Foreground="#7F8D84"
                               FontSize="10" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleButton}"
                            Click="SaveButton_Click"
                            ToolTip="Сохранить">
                        <Canvas Width="16"
                                Height="16"
                                IsHitTestVisible="False">
                            <Path Style="{StaticResource ButtonIconPath}"
                                  Data="M 3,2.5 L 11.5,2.5 L 13.5,4.5 L 13.5,13.5 L 2.5,13.5 L 2.5,2.5 Z" />
                            <Path Style="{StaticResource ButtonIconPath}"
                                  Data="M 5,2.5 L 5,6 L 11,6 L 11,2.5" />
                            <Path Style="{StaticResource ButtonIconPath}"
                                  Data="M 5,10.5 L 11,10.5 L 11,13.5 L 5,13.5 Z" />
                        </Canvas>
                    </Button>
                    <Button Style="{StaticResource TitleButton}"
                            Margin="0"
                            Click="CloseButton_Click"
                            ToolTip="Закрыть">
                        <Canvas Width="16"
                                Height="16"
                                IsHitTestVisible="False">
                            <Path Style="{StaticResource ButtonIconPath}"
                                  Data="M 4,4 L 12,12 M 12,4 L 4,12" />
                        </Canvas>
                    </Button>
                </StackPanel>
            </Grid>

            <ui:LiquidHoverBorder Grid.Row="1"
                                     Margin="12,10,12,12"
                                     Padding="16"
                                     CornerRadius="10"
                                     BaseColor="#101512"
                                     IsLiquidEnabled="False"
                                     SurfaceOpacity="0.20"
                                     BorderBrush="#25342C"
                                     BorderThickness="1">
    <DockPanel LastChildFill="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Настройки Избранного"
                           Foreground="#F4F8F5"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock Text="Подключи Spotify и назначь клавиши для изменения Избранного и проверки статуса текущего трека."
                           Margin="0,4,0,18"
                           Foreground="#AEBDB4"
                           FontSize="12"
                           TextWrapping="Wrap" />

                <TextBlock Text="Spotify Client ID"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBox x:Name="ClientIdBox" />

                <TextBlock Text="Redirect URI"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,14,0,6" />
                <TextBox x:Name="RedirectUriBox"
                         IsReadOnly="True"
                         Foreground="#CFE1D5" />

                <ui:LiquidHoverBorder Margin="0,16,0,0"
                                         Padding="12"
                                         CornerRadius="8"
                                         BorderBrush="#334139"
                                         BorderThickness="1"
                                         IsLiquidEnabled="False"
                                         SurfaceOpacity="0.20"
                                         BaseColor="#18201B">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Подключение Spotify"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10" />

                        <TextBlock x:Name="SpotifyConnectionStatusText"
                                   Grid.Row="1"
                                   Foreground="#9ECFB1"
                                   FontSize="12"
                                   Margin="0,0,0,10" />

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <Button x:Name="LoginButton"
                                    Style="{StaticResource SettingsButton}"
                                    Width="124"
                                    Margin="0,0,8,0"
                                    Click="LoginButton_Click">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Canvas Width="16"
                                            Height="16"
                                            Margin="0,0,7,0"
                                            IsHitTestVisible="False">
                                        <Ellipse Width="16"
                                                 Height="16"
                                                 Fill="#1ED760" />
                                        <Path Data="M 4,6.1 C 6.6,5.3 9.5,5.5 12,6.7"
                                              Stroke="#0F1511"
                                              StrokeThickness="1.35"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                        <Path Data="M 4.6,8.4 C 6.8,7.8 9,8.1 11.3,9"
                                              Stroke="#0F1511"
                                              StrokeThickness="1.2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                        <Path Data="M 5.2,10.5 C 6.8,10.1 8.5,10.2 10.2,10.9"
                                              Stroke="#0F1511"
                                              StrokeThickness="1.1"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Canvas>
                                    <TextBlock Text="Spotify" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="LogoutButton"
                                    Style="{StaticResource SettingsButton}"
                                    Width="100"
                                    Click="LogoutButton_Click">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Canvas Width="16"
                                            Height="16"
                                            Margin="0,0,7,0"
                                            IsHitTestVisible="False">
                                        <Path Style="{StaticResource ButtonIconPath}"
                                              Data="M 3,3 L 8,3 L 8,13 L 3,13 Z" />
                                        <Path Style="{StaticResource ButtonIconPath}"
                                              Data="M 8,8 L 14,8 M 11,5 L 14,8 L 11,11" />
                                    </Canvas>
                                    <TextBlock Text="Выйти" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </ui:LiquidHoverBorder>

                <ui:LiquidHoverBorder Margin="0,16,0,0"
                                         Padding="12"
                                         CornerRadius="8"
                                         BorderBrush="#334139"
                                         BorderThickness="1"
                                         IsLiquidEnabled="False"
                                         SurfaceOpacity="0.20"
                                         BaseColor="#18201B">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Клавиша Избранного"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="FavoriteHotkeyBox"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewKeyDown="FavoriteHotkeyBox_PreviewKeyDown"
                                     GotKeyboardFocus="FavoriteHotkeyBox_GotKeyboardFocus"
                                     ToolTip="Кликни сюда и нажми клавишу добавления/удаления из Избранного" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource SettingsButton}"
                                    Width="42"
                                    Margin="8,0,0,0"
                                    Click="ClearHotkeyButton_Click"
                                    ToolTip="Очистить клавишу">
                                <Canvas Width="15"
                                        Height="15"
                                        IsHitTestVisible="False">
                                    <Path Style="{StaticResource ButtonIconPath}"
                                          Data="M 4,5 L 11,5 M 5.6,5 L 6,3 L 9,3 L 9.4,5 M 6,5 L 6.4,12.5 L 9.6,12.5 L 10,5" />
                                </Canvas>
                            </Button>
                        </Grid>
                    </Grid>
                </ui:LiquidHoverBorder>

                <ui:LiquidHoverBorder Margin="0,12,0,0"
                                         Padding="12"
                                         CornerRadius="8"
                                         BorderBrush="#334139"
                                         BorderThickness="1"
                                         IsLiquidEnabled="False"
                                         SurfaceOpacity="0.20"
                                         BaseColor="#18201B">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Клавиша статуса Избранного"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="FavoriteStatusHotkeyBox"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewKeyDown="FavoriteStatusHotkeyBox_PreviewKeyDown"
                                     GotKeyboardFocus="FavoriteStatusHotkeyBox_GotKeyboardFocus"
                                     ToolTip="Кликни сюда и нажми клавишу проверки статуса Избранного" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource SettingsButton}"
                                    Width="42"
                                    Margin="8,0,0,0"
                                    Click="ClearStatusHotkeyButton_Click"
                                    ToolTip="Очистить клавишу статуса">
                                <Canvas Width="15"
                                        Height="15"
                                        IsHitTestVisible="False">
                                    <Path Style="{StaticResource ButtonIconPath}"
                                          Data="M 4,5 L 11,5 M 5.6,5 L 6,3 L 9,3 L 9.4,5 M 6,5 L 6.4,12.5 L 9.6,12.5 L 10,5" />
                                </Canvas>
                            </Button>
                        </Grid>
                    </Grid>
                </ui:LiquidHoverBorder>

                <TextBlock Text="Клавиша статуса получает через Spotify только текущий трек. Если трек уже есть в кеше, статус берется из кеша; если трек новый, статус Избранного проверяется один раз и кеш обновляется."
                           Margin="0,10,0,0"
                           Foreground="#AEBDB4"
                           FontSize="11"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="StatusText"
                           Margin="0,16,0,0"
                           Foreground="#9ECFB1"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
            </ui:LiquidHoverBorder>
        </Grid>
    </ui:LiquidHoverBorder>
</Window>
