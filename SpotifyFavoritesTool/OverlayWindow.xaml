<Window x:Class="SpotifyFavoritesTool.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SpotifyFavoritesTool"
        Width="462"
        Height="150"
        MinWidth="390"
        MinHeight="132"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        KeyboardNavigation.TabNavigation="None"
        KeyboardNavigation.ControlTabNavigation="None"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="OverlayIconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="local:RippleEffectBehavior.IsEnabled" Value="True" />
            <Setter Property="local:RippleEffectBehavior.RippleBrush" Value="#1ED760" />
            <Setter Property="local:RippleEffectBehavior.PressedOpacity" Value="0.24" />
            <Setter Property="local:RippleEffectBehavior.DurationMilliseconds" Value="420" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" />
                            <Canvas x:Name="RippleHost"
                                    ClipToBounds="True"
                                    IsHitTestVisible="False">
                                <Canvas.OpacityMask>
                                    <VisualBrush Visual="{Binding ElementName=Root}" />
                                </Canvas.OpacityMask>
                            </Canvas>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#203A29" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1ED760" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportButton" BasedOn="{StaticResource OverlayIconButton}" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="HistoryPlayButton" BasedOn="{StaticResource OverlayIconButton}" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
    </Window.Resources>

    <local:LiquidHoverBorder x:Name="OverlayRoot"
                             Margin="7"
                             Padding="12"
                             CornerRadius="12"
                             BaseColor="#101512"
                             SurfaceOpacity="1"
                             BorderBrush="#365142"
                             BorderThickness="1"
                             SnapsToDevicePixels="True"
                             MouseLeftButtonDown="OverlayRoot_MouseLeftButtonDown">
        <local:LiquidHoverBorder.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.35"
                              Color="#000000" />
        </local:LiquidHoverBorder.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
                <RowDefinition x:Name="HistoryRow" Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="74" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="42" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ArtworkFrame"
                    Width="64"
                    Height="64"
                    CornerRadius="8"
                    Background="#202824"
                    BorderBrush="#334139"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    ClipToBounds="True">
                <Border.ToolTip>
                    <ToolTip x:Name="AlbumArtPreviewToolTip"
                             Placement="Mouse"
                             IsEnabled="False">
                        <Border Width="256"
                                Height="256"
                                CornerRadius="10"
                                Background="#101512"
                                BorderBrush="#365142"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <Image x:Name="AlbumArtPreview"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                    </ToolTip>
                </Border.ToolTip>
                <Grid>
                    <Image x:Name="AlbumArt"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           ImageFailed="AlbumArt_ImageFailed" />
                    <TextBlock x:Name="AlbumPlaceholder"
                               Text="SP"
                               Foreground="#6F7D74"
                               FontWeight="Bold"
                               FontSize="17"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  Margin="0,2,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="27" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="TrackTitle"
                           Foreground="#F7FAF8"
                           FontSize="15"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ArtistText"
                           Grid.Row="1"
                           Foreground="#B9C4BE"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="FavoriteText"
                           Grid.Row="2"
                           Foreground="#7F8D84"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <Button x:Name="FavoriteButton"
                    Grid.Column="2"
                    Style="{StaticResource OverlayIconButton}"
                    Content="♡"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="FavoriteButton_Click"
                    ToolTip="Переключить Избранное для текущего трека" />

            <StackPanel Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom">
                <Button x:Name="PreviousButton"
                        Style="{StaticResource TransportButton}"
                        Content="⏮"
                        Click="PreviousButton_Click"
                        ToolTip="Предыдущий трек" />
                <Button x:Name="PlayPauseButton"
                        Style="{StaticResource TransportButton}"
                        Click="PlayPauseButton_Click"
                        ToolTip="Пауза / воспроизведение">
                    <Canvas Width="16"
                            Height="16"
                            IsHitTestVisible="False">
                        <Path x:Name="PlayGlyph"
                              Data="M 4,3 L 13,8 L 4,13 Z"
                              Fill="#F4F8F5"
                              Visibility="Collapsed" />
                        <Rectangle x:Name="PauseGlyphLeft"
                                   Width="3.2"
                                   Height="10"
                                   RadiusX="1"
                                   RadiusY="1"
                                   Fill="#F4F8F5"
                                   Canvas.Left="4"
                                   Canvas.Top="3" />
                        <Rectangle x:Name="PauseGlyphRight"
                                   Width="3.2"
                                   Height="10"
                                   RadiusX="1"
                                   RadiusY="1"
                                   Fill="#F4F8F5"
                                   Canvas.Left="9"
                                   Canvas.Top="3" />
                    </Canvas>
                </Button>
                <Button x:Name="NextButton"
                        Style="{StaticResource TransportButton}"
                        Content="⏭"
                        Click="NextButton_Click"
                        ToolTip="Следующий трек" />
                <Button x:Name="HistoryToggleButton"
                        Style="{StaticResource TransportButton}"
                        Margin="0"
                        Click="HistoryToggleButton_Click"
                        ToolTip="Показать воспроизводившиеся ранее треки">
                    <Canvas Width="16"
                            Height="16"
                            IsHitTestVisible="False">
                        <Path Data="M 3,4 L 13,4 M 3,8 L 13,8 M 3,12 L 13,12"
                              Stroke="#F4F8F5"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Canvas>
                </Button>
            </StackPanel>

            <local:LiquidHoverBorder x:Name="HistoryPanel"
                                     Grid.Row="2"
                                     Grid.ColumnSpan="3"
                                     Margin="0,12,0,0"
                                     Padding="10"
                                     Height="276"
                                     Visibility="Collapsed"
                                     CornerRadius="10"
                                     BaseColor="#141B17"
                                     BorderBrush="#32483C"
                                     BorderThickness="1"
                                     IsLiquidEnabled="False"
                                     SurfaceOpacity="0.20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Воспроизводилось ранее"
                               Foreground="#F4F8F5"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,0,0,8" />
                    <ListBox x:Name="CachedTracksList"
                             Grid.Row="1"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="IsTabStop" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="HistoryItemRoot"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="CoverColumn" Width="0" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="HistoryCover"
                                                Width="34"
                                                Height="34"
                                                Margin="0,0,8,0"
                                                CornerRadius="6"
                                                Background="#202824"
                                                ClipToBounds="True"
                                                Visibility="Collapsed">
                                            <Image Source="{Binding AlbumImageUrl}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>

                                        <Grid Grid.Column="1"
                                              VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding DisplayLine}"
                                                       Foreground="#F4F8F5"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding NowPlayingText}"
                                                       Foreground="#8DE6B1"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </Grid>

                                        <StackPanel x:Name="HistoryActions"
                                                    Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Visibility="Collapsed">
                                            <Button Style="{StaticResource HistoryPlayButton}"
                                                    Tag="{Binding}"
                                                    Click="CachedTrackPlayButton_Click"
                                                    ToolTip="Запустить этот трек">
                                                <Canvas Width="14"
                                                        Height="14"
                                                        IsHitTestVisible="False">
                                                    <Path Data="M 4,2.5 L 12,7 L 4,11.5 Z"
                                                          Fill="#F4F8F5" />
                                                </Canvas>
                                            </Button>
                                            <Button Style="{StaticResource HistoryPlayButton}"
                                                    Tag="{Binding}"
                                                    Content="{Binding FavoriteGlyph}"
                                                    Click="CachedTrackFavoriteButton_Click"
                                                    ToolTip="Переключить Избранное" />
                                        </StackPanel>

                                        <TextBlock x:Name="HistoryFavoriteGlyph"
                                                   Grid.Column="2"
                                                   Text="{Binding FavoriteGlyph}"
                                                   Foreground="#8DE6B1"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="HistoryItemRoot" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="HistoryItemRoot" Property="Background" Value="#40202A24" />
                                        <Setter TargetName="HistoryItemRoot" Property="BorderBrush" Value="#314638" />
                                        <Setter TargetName="CoverColumn" Property="Width" Value="42" />
                                        <Setter TargetName="HistoryCover" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="HistoryActions" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="HistoryFavoriteGlyph" Property="Visibility" Value="Collapsed" />
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </local:LiquidHoverBorder>
        </Grid>
    </local:LiquidHoverBorder>
</Window>
