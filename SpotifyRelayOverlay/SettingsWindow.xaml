<Window x:Class="SpotifyRelayOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки Избранного"
        Width="620"
        Height="680"
        MinWidth="540"
        MinHeight="440"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="#101512"
        Foreground="#F4F8F5">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="CaretBrush" Value="#1ED760" />
        </Style>

        <Style x:Key="SettingsButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1ED760" />
                                <Setter Property="Foreground" Value="#0F1511" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="18" LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Style="{StaticResource SettingsButton}"
                    Content="✓ Сохранить"
                    Width="116"
                    Margin="0,0,8,0"
                    Click="SaveButton_Click" />
            <Button x:Name="LoginButton"
                    Style="{StaticResource SettingsButton}"
                    Content="↗ Spotify"
                    Width="116"
                    Margin="0,0,8,0"
                    Click="LoginButton_Click" />
            <Button Style="{StaticResource SettingsButton}"
                    Content="⎋ Выйти"
                    Width="92"
                    Margin="0,0,8,0"
                    Click="LogoutButton_Click" />
            <Button Style="{StaticResource SettingsButton}"
                    Content="Закрыть"
                    Width="90"
                    Click="CloseButton_Click" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Настройки Избранного"
                           Foreground="#F4F8F5"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock Text="Подключи Spotify и назначь клавиши для изменения Избранного и проверки актуального статуса."
                           Margin="0,4,0,18"
                           Foreground="#AEBDB4"
                           FontSize="12"
                           TextWrapping="Wrap" />

                <TextBlock Text="Spotify Client ID"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBox x:Name="ClientIdBox" />

                <TextBlock Text="Redirect URI"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,14,0,6" />
                <TextBox x:Name="RedirectUriBox"
                         IsReadOnly="True"
                         Foreground="#CFE1D5" />

                <Border Margin="0,16,0,0"
                        Padding="12"
                        CornerRadius="8"
                        BorderBrush="#334139"
                        BorderThickness="1"
                        Background="#18201B">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Клавиша Избранного"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="FavoriteHotkeyBox"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewKeyDown="FavoriteHotkeyBox_PreviewKeyDown"
                                     GotKeyboardFocus="FavoriteHotkeyBox_GotKeyboardFocus"
                                     ToolTip="Кликни сюда и нажми клавишу добавления/удаления из Избранного" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource SettingsButton}"
                                    Content="Очистить"
                                    Width="96"
                                    Margin="8,0,0,0"
                                    Click="ClearHotkeyButton_Click" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="12"
                        CornerRadius="8"
                        BorderBrush="#334139"
                        BorderThickness="1"
                        Background="#18201B">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Клавиша статуса Избранного"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="FavoriteStatusHotkeyBox"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewKeyDown="FavoriteStatusHotkeyBox_PreviewKeyDown"
                                     GotKeyboardFocus="FavoriteStatusHotkeyBox_GotKeyboardFocus"
                                     ToolTip="Кликни сюда и нажми клавишу проверки статуса через Spotify" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource SettingsButton}"
                                    Content="Очистить"
                                    Width="96"
                                    Margin="8,0,0,0"
                                    Click="ClearStatusHotkeyButton_Click" />
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="Клавиша статуса по нажатию получает текущий трек и актуальный статус Избранного через Spotify API. Повторных попыток после 429 нет."
                           Margin="0,10,0,0"
                           Foreground="#AEBDB4"
                           FontSize="11"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="StatusText"
                           Margin="0,16,0,0"
                           Foreground="#9ECFB1"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
