<Window x:Class="SpotifyRelayOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки Spotify"
        Width="540"
        Height="390"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#111713"
        Foreground="#F4F8F5">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Spotify Client ID"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6" />
        <TextBox x:Name="ClientIdBox"
                 Grid.Row="1"
                 Height="32"
                 Padding="8,5"
                 Background="#202A24"
                 Foreground="#F4F8F5"
                 BorderBrush="#3D4B42"
                 CaretBrush="#1ED760" />

        <TextBlock Grid.Row="2"
                   Text="Redirect URI"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,16,0,6" />
        <TextBox x:Name="RedirectUriBox"
                 Grid.Row="3"
                 Height="32"
                 Padding="8,5"
                 IsReadOnly="True"
                 Background="#202A24"
                 Foreground="#CFE1D5"
                 BorderBrush="#3D4B42" />

        <Border Grid.Row="4"
                Margin="0,16,0,0"
                Padding="10"
                CornerRadius="6"
                BorderBrush="#334139"
                BorderThickness="1"
                Background="#18201B">
            <StackPanel>
                <CheckBox x:Name="SafeModeBox"
                          Content="Безопасный режим для игр"
                          Foreground="#F4F8F5"
                          FontWeight="SemiBold" />
                <TextBlock Margin="23,6,0,0"
                           Foreground="#AEBDB4"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Text="Отключает глобальные хоткеи и агрессивное удержание поверх окон. Оверлей становится спокойнее для античитов, но может скрываться за полноэкранной игрой." />
            </StackPanel>
        </Border>

        <TextBlock x:Name="StatusText"
                   Grid.Row="5"
                   Margin="0,16,0,0"
                   Foreground="#9ECFB1"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Сохранить"
                    Width="96"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="SaveButton_Click" />
            <Button x:Name="LoginButton"
                    Content="Войти в Spotify"
                    Width="122"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="LoginButton_Click" />
            <Button Content="Выйти"
                    Width="72"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="LogoutButton_Click" />
            <Button Content="Закрыть"
                    Width="76"
                    Height="34"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
