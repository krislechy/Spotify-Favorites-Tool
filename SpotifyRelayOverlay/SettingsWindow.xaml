<Window x:Class="SpotifyRelayOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки Spotify"
        Width="560"
        Height="360"
        MinWidth="500"
        MinHeight="330"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="#111713"
        Foreground="#F4F8F5">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="CaretBrush" Value="#1ED760" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="18" LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Сохранить"
                    Width="104"
                    Margin="0,0,8,0"
                    Click="SaveButton_Click" />
            <Button x:Name="LoginButton"
                    Content="Войти в Spotify"
                    Width="132"
                    Margin="0,0,8,0"
                    Click="LoginButton_Click" />
            <Button Content="Выйти"
                    Width="82"
                    Margin="0,0,8,0"
                    Click="LogoutButton_Click" />
            <Button Content="Закрыть"
                    Width="86"
                    Click="CloseButton_Click" />
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Spotify Client ID"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <TextBox x:Name="ClientIdBox" />

            <TextBlock Text="Redirect URI"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,16,0,6" />
            <TextBox x:Name="RedirectUriBox"
                     IsReadOnly="True"
                     Foreground="#CFE1D5" />

            <Border Margin="0,16,0,0"
                    Padding="12"
                    CornerRadius="6"
                    BorderBrush="#334139"
                    BorderThickness="1"
                    Background="#18201B">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Код клавиши"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <TextBox x:Name="LikeHotkeyBox"
                             Grid.Column="1" />
                    <TextBlock Grid.Column="2"
                               Margin="10,0,0,0"
                               Foreground="#AEBDB4"
                               FontSize="11"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Text="Введи VK-код из KeyInspector, например 0xB3 для медиа-кнопки. Эта клавиша будет переключать избранное текущего трека." />
                </Grid>
            </Border>

            <TextBlock x:Name="StatusText"
                       Margin="0,16,0,0"
                       Foreground="#9ECFB1"
                       TextWrapping="Wrap" />
        </StackPanel>
    </DockPanel>
</Window>
