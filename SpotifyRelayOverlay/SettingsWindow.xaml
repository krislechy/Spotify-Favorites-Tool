<Window x:Class="SpotifyRelayOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SpotifyRelayOverlay"
        Title="Настройки Избранного"
        Width="620"
        Height="680"
        MinWidth="540"
        MinHeight="440"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="#F4F8F5">
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1ED760" />
                                <Setter Property="Foreground" Value="#0F1511" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleButton" BasedOn="{StaticResource IconButton}" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="CaretBrush" Value="#1ED760" />
        </Style>

        <Style x:Key="SettingsButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1ED760" />
                                <Setter Property="Foreground" Value="#0F1511" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <local:LiquidHoverBorder Margin="8"
                             CornerRadius="12"
                             BaseColor="#101512"
                             BorderBrush="#2A3A31"
                             BorderThickness="1"
                             SnapsToDevicePixels="True">
        <local:LiquidHoverBorder.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.28"
                              Color="#000000" />
        </local:LiquidHoverBorder.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Margin="10,8,10,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="28"
                        Height="28"
                        CornerRadius="7"
                        Background="#1ED760">
                    <TextBlock Text="♥"
                               Foreground="#0F1511"
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Настройки Избранного"
                               Foreground="#F4F8F5"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Spotify, горячие клавиши и авторизация"
                               Foreground="#7F8D84"
                               FontSize="10" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleButton}"
                            Content="─"
                            Click="MinimizeButton_Click"
                            ToolTip="Свернуть" />
                    <Button Style="{StaticResource TitleButton}"
                            Content="×"
                            Margin="0"
                            Click="CloseButton_Click"
                            ToolTip="Закрыть" />
                </StackPanel>
            </Grid>

            <local:LiquidHoverBorder Grid.Row="1"
                                     Margin="12,10,12,12"
                                     Padding="16"
                                     CornerRadius="10"
                                     BaseColor="#101512"
                                     BorderBrush="#25342C"
                                     BorderThickness="1">
    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Style="{StaticResource SettingsButton}"
                    Content="✓ Сохранить"
                    Width="116"
                    Margin="0,0,8,0"
                    Click="SaveButton_Click" />
            <Button x:Name="LoginButton"
                    Style="{StaticResource SettingsButton}"
                    Content="↗ Spotify"
                    Width="116"
                    Margin="0,0,8,0"
                    Click="LoginButton_Click" />
            <Button Style="{StaticResource SettingsButton}"
                    Content="⎋ Выйти"
                    Width="92"
                    Margin="0,0,8,0"
                    Click="LogoutButton_Click" />
            <Button Style="{StaticResource SettingsButton}"
                    Content="Закрыть"
                    Width="90"
                    Click="CloseButton_Click" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Настройки Избранного"
                           Foreground="#F4F8F5"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock Text="Подключи Spotify и назначь клавиши для изменения Избранного и проверки статуса текущего трека."
                           Margin="0,4,0,18"
                           Foreground="#AEBDB4"
                           FontSize="12"
                           TextWrapping="Wrap" />

                <TextBlock Text="Spotify Client ID"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <TextBox x:Name="ClientIdBox" />

                <TextBlock Text="Redirect URI"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,14,0,6" />
                <TextBox x:Name="RedirectUriBox"
                         IsReadOnly="True"
                         Foreground="#CFE1D5" />

                <local:LiquidHoverBorder Margin="0,16,0,0"
                                         Padding="12"
                                         CornerRadius="8"
                                         BorderBrush="#334139"
                                         BorderThickness="1"
                                         BaseColor="#18201B">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Клавиша Избранного"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="FavoriteHotkeyBox"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewKeyDown="FavoriteHotkeyBox_PreviewKeyDown"
                                     GotKeyboardFocus="FavoriteHotkeyBox_GotKeyboardFocus"
                                     ToolTip="Кликни сюда и нажми клавишу добавления/удаления из Избранного" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource SettingsButton}"
                                    Content="Очистить"
                                    Width="96"
                                    Margin="8,0,0,0"
                                    Click="ClearHotkeyButton_Click" />
                        </Grid>
                    </Grid>
                </local:LiquidHoverBorder>

                <local:LiquidHoverBorder Margin="0,12,0,0"
                                         Padding="12"
                                         CornerRadius="8"
                                         BorderBrush="#334139"
                                         BorderThickness="1"
                                         BaseColor="#18201B">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Клавиша статуса Избранного"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="FavoriteStatusHotkeyBox"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewKeyDown="FavoriteStatusHotkeyBox_PreviewKeyDown"
                                     GotKeyboardFocus="FavoriteStatusHotkeyBox_GotKeyboardFocus"
                                     ToolTip="Кликни сюда и нажми клавишу проверки статуса Избранного" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource SettingsButton}"
                                    Content="Очистить"
                                    Width="96"
                                    Margin="8,0,0,0"
                                    Click="ClearStatusHotkeyButton_Click" />
                        </Grid>
                    </Grid>
                </local:LiquidHoverBorder>

                <TextBlock Text="Клавиша статуса получает через Spotify только текущий трек. Если трек уже есть в кеше, статус берется из кеша; если трек новый, статус Избранного проверяется один раз и кеш обновляется."
                           Margin="0,10,0,0"
                           Foreground="#AEBDB4"
                           FontSize="11"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="StatusText"
                           Margin="0,16,0,0"
                           Foreground="#9ECFB1"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
            </local:LiquidHoverBorder>
        </Grid>
    </local:LiquidHoverBorder>
</Window>
