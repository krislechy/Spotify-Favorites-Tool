<Window x:Class="SpotifyRelayOverlay.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Height="132"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        KeyboardNavigation.TabNavigation="None"
        KeyboardNavigation.ControlTabNavigation="None"
        Loaded="Window_Loaded">
    <Border CornerRadius="8"
            Background="#F0161B18"
            BorderBrush="#4936D87B"
            BorderThickness="1"
            Padding="11"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ArtworkColumn" Width="74" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="IconColumn" Width="66" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ArtworkFrame"
                    Width="64"
                    Height="64"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    CornerRadius="6"
                    Background="#202824"
                    BorderBrush="#334139"
                    BorderThickness="1">
                <Grid>
                    <Image x:Name="AlbumArt"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock x:Name="AlbumPlaceholder"
                               Text="SP"
                               Foreground="#6F7D74"
                               FontWeight="Bold"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="ActionText"
                           Foreground="#8DE6B1"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="TrackTitle"
                           Grid.Row="1"
                           Foreground="#F7FAF8"
                           FontSize="16"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ArtistText"
                           Grid.Row="2"
                           Foreground="#B9C4BE"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="FooterText"
                           Text="Spotify Избранное"
                           Grid.Row="3"
                           Foreground="#7F8D84"
                           FontSize="10"
                           VerticalAlignment="Bottom" />
            </Grid>

            <Grid x:Name="IconStage"
                  Grid.Column="2"
                  Width="58"
                  Height="58"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Canvas x:Name="FavoriteIconCanvas"
                        Width="54"
                        Height="54"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Ellipse x:Name="HeartGlow"
                             Canvas.Left="-8"
                             Canvas.Top="-8"
                             Width="70"
                             Height="70"
                             Opacity="0"
                             IsHitTestVisible="False"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#D01ED760"
                                              Offset="0" />
                                <GradientStop Color="#771ED760"
                                              Offset="0.44" />
                                <GradientStop Color="#001ED760"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <BlurEffect Radius="13" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="GlowScale"
                                            ScaleX="0.55"
                                            ScaleY="0.55" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Path x:Name="SparkleTop"
                          Data="M 27,2 L 29.2,8 L 35,10 L 29.2,12 L 27,18 L 24.8,12 L 19,10 L 24.8,8 Z"
                          Fill="#D8FFE6"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="SparkleTopScale"
                                                ScaleX="0.25"
                                                ScaleY="0.25" />
                                <RotateTransform x:Name="SparkleTopRotate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="SparkleLeft"
                          Data="M 8,16 L 9.4,20 L 13.5,21.4 L 9.4,22.8 L 8,27 L 6.6,22.8 L 2.5,21.4 L 6.6,20 Z"
                          Fill="#A7F6C4"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <ScaleTransform x:Name="SparkleLeftScale"
                                            ScaleX="0.25"
                                            ScaleY="0.25" />
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="SparkleRight"
                          Data="M 46,18 L 47.5,22 L 51.5,23.5 L 47.5,25 L 46,29 L 44.5,25 L 40.5,23.5 L 44.5,22 Z"
                          Fill="#E5FFEE"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <ScaleTransform x:Name="SparkleRightScale"
                                            ScaleX="0.25"
                                            ScaleY="0.25" />
                        </Path.RenderTransform>
                    </Path>

                    <Ellipse x:Name="DustOne"
                             Canvas.Left="12"
                             Canvas.Top="17"
                             Width="4"
                             Height="4"
                             Fill="#8F9E90"
                             Opacity="0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="DustOneTranslate" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="DustTwo"
                             Canvas.Left="39"
                             Canvas.Top="17"
                             Width="3.5"
                             Height="3.5"
                             Fill="#6F7B70"
                             Opacity="0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="DustTwoTranslate" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="DustThree"
                             Canvas.Left="25"
                             Canvas.Top="38"
                             Width="4"
                             Height="4"
                             Fill="#A9B6AA"
                             Opacity="0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="DustThreeTranslate" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="DustFour"
                             Canvas.Left="19"
                             Canvas.Top="29"
                             Width="2.8"
                             Height="2.8"
                             Fill="#59645B"
                             Opacity="0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="DustFourTranslate" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="DustFive"
                             Canvas.Left="33"
                             Canvas.Top="31"
                             Width="3"
                             Height="3"
                             Fill="#778377"
                             Opacity="0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="DustFiveTranslate" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="DustSix"
                             Canvas.Left="28"
                             Canvas.Top="23"
                             Width="2.5"
                             Height="2.5"
                             Fill="#B8C3B9"
                             Opacity="0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="DustSixTranslate" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Path x:Name="DropShape"
                          Data="M 27,8 C 35,19 39,25 39,33 C 39,41 33.5,46 27,46 C 20.5,46 15,41 15,33 C 15,25 19,19 27,8 Z"
                          Fill="#1ED760"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="DropScale"
                                                ScaleX="0.25"
                                                ScaleY="0.25" />
                                <TranslateTransform x:Name="DropTranslate"
                                                    Y="-5" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartFill"
                          Data="M 27,47 C 22,42 7,31.5 5.8,19 C 4.8,9 12.5,4 19.4,8.5 C 23.3,11 25.7,14.6 27,17.8 C 28.3,14.6 30.7,11 34.6,8.5 C 41.5,4 49.2,9 48.2,19 C 47,31.5 32,42 27,47 Z"
                          Fill="#1ED760"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="HeartScale"
                                                ScaleX="0.82"
                                                ScaleY="0.82" />
                                <RotateTransform x:Name="HeartRotate"
                                                 Angle="0" />
                                <TranslateTransform x:Name="HeartTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartOutline"
                          Data="M 27,47 C 22,42 7,31.5 5.8,19 C 4.8,9 12.5,4 19.4,8.5 C 23.3,11 25.7,14.6 27,17.8 C 28.3,14.6 30.7,11 34.6,8.5 C 41.5,4 49.2,9 48.2,19 C 47,31.5 32,42 27,47 Z"
                          Fill="Transparent"
                          Stroke="#D5E7DC"
                          StrokeThickness="3"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Opacity="0" />

                    <Path x:Name="CrackLines"
                          Data="M 27,17 L 23,25 L 29,29 L 24,39 M 35,12 L 31,22 L 36,26"
                          Stroke="#101512"
                          StrokeThickness="2.2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Opacity="0" />

                    <Path x:Name="HeartPieceLeft"
                          Data="M 27,47 C 22,42 7,31.5 5.8,19 C 4.8,9 12.5,4 19.4,8.5 C 23.3,11 25.7,14.6 27,17.8 L 24,29 L 27,47 Z"
                          Fill="#6F7C70"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="LeftPieceRotate" />
                                <TranslateTransform x:Name="LeftPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartPieceRight"
                          Data="M 27,47 L 24,29 L 27,17.8 C 28.3,14.6 30.7,11 34.6,8.5 C 41.5,4 49.2,9 48.2,19 C 47,31.5 32,42 27,47 Z"
                          Fill="#58645B"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="RightPieceRotate" />
                                <TranslateTransform x:Name="RightPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartPieceCenter"
                          Data="M 24,29 L 29,30 L 24,40 L 27,47 L 24,29 Z"
                          Fill="#8B978C"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="CenterPieceRotate" />
                                <TranslateTransform x:Name="CenterPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>
                </Canvas>

                <TextBlock x:Name="ErrorIconText"
                           Text="!"
                           Foreground="#FFC457"
                           FontSize="48"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Border>
</Window>
