<Window x:Class="SpotifyRelayOverlay.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="430"
        Height="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Loaded="Window_Loaded">
    <Border CornerRadius="8"
            Background="#F0161B18"
            BorderBrush="#4936D87B"
            BorderThickness="1"
            Padding="10"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="64" />
            </Grid.ColumnDefinitions>

            <Border Width="62"
                    Height="62"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    CornerRadius="6"
                    Background="#202824"
                    BorderBrush="#334139"
                    BorderThickness="1">
                <Grid>
                    <Image x:Name="AlbumArt"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock x:Name="AlbumPlaceholder"
                               Text="SP"
                               Foreground="#6F7D74"
                               FontWeight="Bold"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="ActionText"
                           Foreground="#8DE6B1"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="TrackTitle"
                           Grid.Row="1"
                           Foreground="#F7FAF8"
                           FontSize="16"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ArtistText"
                           Grid.Row="2"
                           Foreground="#B9C4BE"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="Spotify Favorite Hotkey"
                           Grid.Row="3"
                           Foreground="#7F8D84"
                           FontSize="10"
                           VerticalAlignment="Bottom" />
            </Grid>

            <TextBlock x:Name="HeartText"
                       Grid.Column="2"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#1ED760"
                       FontSize="48"
                       FontWeight="Bold" />
        </Grid>
    </Border>
</Window>
