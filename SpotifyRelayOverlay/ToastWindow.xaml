<Window x:Class="SpotifyRelayOverlay.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Height="132"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        KeyboardNavigation.TabNavigation="None"
        KeyboardNavigation.ControlTabNavigation="None"
        Loaded="Window_Loaded">
    <Border CornerRadius="8"
            Background="#F0161B18"
            BorderBrush="#4936D87B"
            BorderThickness="1"
            Padding="11"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ArtworkColumn" Width="74" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="IconColumn" Width="78" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ArtworkFrame"
                    Width="64"
                    Height="64"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    CornerRadius="6"
                    Background="#202824"
                    BorderBrush="#334139"
                    BorderThickness="1">
                <Grid>
                    <Image x:Name="AlbumArt"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock x:Name="AlbumPlaceholder"
                               Text="SP"
                               Foreground="#6F7D74"
                               FontWeight="Bold"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="ActionText"
                           Foreground="#8DE6B1"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="TrackTitle"
                           Grid.Row="1"
                           Foreground="#F7FAF8"
                           FontSize="16"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ArtistText"
                           Grid.Row="2"
                           Foreground="#B9C4BE"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="FooterText"
                           Text="Spotify Избранное"
                           Grid.Row="3"
                           Foreground="#7F8D84"
                           FontSize="10"
                           VerticalAlignment="Bottom" />
            </Grid>

            <Grid x:Name="IconStage"
                  Grid.Column="2"
                  Width="72"
                  Height="72"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Canvas x:Name="FavoriteIconCanvas"
                        Width="54"
                        Height="54"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Path x:Name="DivineRays"
                          Data="M 27,-7 L 27,8 M 10,0 L 17,11 M 44,0 L 37,11 M -5,27 L 10,27 M 59,27 L 44,27 M 10,54 L 18,43 M 44,54 L 36,43"
                          Stroke="#E8FFF0"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Opacity="0"
                          IsHitTestVisible="False"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.Effect>
                            <BlurEffect Radius="1.2" />
                        </Path.Effect>
                        <Path.RenderTransform>
                            <ScaleTransform x:Name="DivineRaysScale"
                                            ScaleX="0.65"
                                            ScaleY="0.65" />
                        </Path.RenderTransform>
                    </Path>

                    <Ellipse x:Name="HaloRing"
                             Canvas.Left="-9"
                             Canvas.Top="-9"
                             Width="72"
                             Height="72"
                             Stroke="#DFFFF0"
                             StrokeThickness="1.8"
                             Opacity="0"
                             IsHitTestVisible="False"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="HaloRingScale"
                                            ScaleX="0.55"
                                            ScaleY="0.55" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="DarkMist"
                             Canvas.Left="-7"
                             Canvas.Top="-5"
                             Width="68"
                             Height="62"
                             Opacity="0"
                             IsHitTestVisible="False"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#993B4840"
                                              Offset="0" />
                                <GradientStop Color="#66171D19"
                                              Offset="0.58" />
                                <GradientStop Color="#00101512"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <BlurEffect Radius="8" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="DarkMistScale"
                                            ScaleX="0.62"
                                            ScaleY="0.62" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="HeartGlow"
                             Canvas.Left="-2"
                             Canvas.Top="-2"
                             Width="58"
                             Height="58"
                             Opacity="0"
                             IsHitTestVisible="False"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#A01ED760"
                                              Offset="0" />
                                <GradientStop Color="#331ED760"
                                              Offset="0.52" />
                                <GradientStop Color="#001ED760"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <BlurEffect Radius="9" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="GlowScale"
                                            ScaleX="0.55"
                                            ScaleY="0.55" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Path x:Name="SparkleTop"
                          Data="M 27,2 L 29.2,8 L 35,10 L 29.2,12 L 27,18 L 24.8,12 L 19,10 L 24.8,8 Z"
                          Fill="#D8FFE6"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="SparkleTopScale"
                                                ScaleX="0.25"
                                                ScaleY="0.25" />
                                <RotateTransform x:Name="SparkleTopRotate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="SparkleLeft"
                          Data="M 8,16 L 9.4,20 L 13.5,21.4 L 9.4,22.8 L 8,27 L 6.6,22.8 L 2.5,21.4 L 6.6,20 Z"
                          Fill="#A7F6C4"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <ScaleTransform x:Name="SparkleLeftScale"
                                            ScaleX="0.25"
                                            ScaleY="0.25" />
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="SparkleRight"
                          Data="M 46,18 L 47.5,22 L 51.5,23.5 L 47.5,25 L 46,29 L 44.5,25 L 40.5,23.5 L 44.5,22 Z"
                          Fill="#E5FFEE"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <ScaleTransform x:Name="SparkleRightScale"
                                            ScaleX="0.25"
                                            ScaleY="0.25" />
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="SparkleBottom"
                          Data="M 29,47 L 30.2,50 L 33.5,51.2 L 30.2,52.4 L 29,55.5 L 27.8,52.4 L 24.5,51.2 L 27.8,50 Z"
                          Fill="#F3FFF7"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <ScaleTransform x:Name="SparkleBottomScale"
                                            ScaleX="0.25"
                                            ScaleY="0.25" />
                        </Path.RenderTransform>
                    </Path>

                    <Ellipse x:Name="AshOne"
                             Canvas.Left="5"
                             Canvas.Top="10"
                             Width="5"
                             Height="5"
                             Fill="#7A8B7F"
                             Opacity="0"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="AshOneTranslate" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="AshTwo"
                             Canvas.Left="43"
                             Canvas.Top="11"
                             Width="4"
                             Height="4"
                             Fill="#4E5C53"
                             Opacity="0"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="AshTwoTranslate" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="AshThree"
                             Canvas.Left="31"
                             Canvas.Top="45"
                             Width="4"
                             Height="4"
                             Fill="#A8B5AA"
                             Opacity="0"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="AshThreeTranslate" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Path x:Name="DropShape"
                          Data="M 27,8 C 35,19 39,25 39,33 C 39,41 33.5,46 27,46 C 20.5,46 15,41 15,33 C 15,25 19,19 27,8 Z"
                          Fill="#1ED760"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="DropScale"
                                                ScaleX="0.25"
                                                ScaleY="0.25" />
                                <TranslateTransform x:Name="DropTranslate"
                                                    Y="-5" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartFill"
                          Data="M 27,47 C 22,42 7,31.5 5.8,19 C 4.8,9 12.5,4 19.4,8.5 C 23.3,11 25.7,14.6 27,17.8 C 28.3,14.6 30.7,11 34.6,8.5 C 41.5,4 49.2,9 48.2,19 C 47,31.5 32,42 27,47 Z"
                          Fill="#1ED760"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="HeartScale"
                                                ScaleX="0.82"
                                                ScaleY="0.82" />
                                <RotateTransform x:Name="HeartRotate"
                                                 Angle="0" />
                                <TranslateTransform x:Name="HeartTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartOutline"
                          Data="M 27,47 C 22,42 7,31.5 5.8,19 C 4.8,9 12.5,4 19.4,8.5 C 23.3,11 25.7,14.6 27,17.8 C 28.3,14.6 30.7,11 34.6,8.5 C 41.5,4 49.2,9 48.2,19 C 47,31.5 32,42 27,47 Z"
                          Fill="Transparent"
                          Stroke="#D5E7DC"
                          StrokeThickness="3"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Opacity="0" />

                    <Path x:Name="CrackLines"
                          Data="M 27,17 L 23,25 L 29,29 L 24,39 M 35,12 L 31,22 L 36,26"
                          Stroke="#101512"
                          StrokeThickness="2.2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Opacity="0" />

                    <Path x:Name="HeartPieceLeft"
                          Data="M 27,47 C 22,42 7,31.5 5.8,19 C 4.8,9 12.5,4 19.4,8.5 C 23.3,11 25.7,14.6 27,17.8 L 24,29 L 27,47 Z"
                          Fill="#8CA896"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="LeftPieceRotate" />
                                <TranslateTransform x:Name="LeftPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartPieceRight"
                          Data="M 27,47 L 24,29 L 27,17.8 C 28.3,14.6 30.7,11 34.6,8.5 C 41.5,4 49.2,9 48.2,19 C 47,31.5 32,42 27,47 Z"
                          Fill="#789181"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="RightPieceRotate" />
                                <TranslateTransform x:Name="RightPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartPieceCenter"
                          Data="M 24,29 L 29,30 L 24,40 L 27,47 L 24,29 Z"
                          Fill="#A9BDAF"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="CenterPieceRotate" />
                                <TranslateTransform x:Name="CenterPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartPieceTop"
                          Data="M 19.4,8.5 C 23.3,11 25.7,14.6 27,17.8 C 28.3,14.6 30.7,11 34.6,8.5 C 37.5,6.6 40.6,6.2 43.1,7.2 L 34.5,18.2 L 27,17.8 L 19.2,18.2 L 11,7.2 C 13.6,6.2 16.5,6.6 19.4,8.5 Z"
                          Fill="#5F7066"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="TopPieceRotate" />
                                <TranslateTransform x:Name="TopPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartPieceLowerLeft"
                          Data="M 5.8,19 C 7,31.5 22,42 27,47 L 17,34 L 12,23 L 5.8,19 Z"
                          Fill="#56655C"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="LowerLeftPieceRotate" />
                                <TranslateTransform x:Name="LowerLeftPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartPieceLowerRight"
                          Data="M 48.2,19 C 47,31.5 32,42 27,47 L 37,34 L 42,23 L 48.2,19 Z"
                          Fill="#48564E"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="LowerRightPieceRotate" />
                                <TranslateTransform x:Name="LowerRightPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>
                </Canvas>

                <TextBlock x:Name="ErrorIconText"
                           Text="!"
                           Foreground="#FFC457"
                           FontSize="48"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Border>
</Window>
