<Window x:Class="SpotifyRelayOverlay.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Height="132"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        KeyboardNavigation.TabNavigation="None"
        KeyboardNavigation.ControlTabNavigation="None"
        Loaded="Window_Loaded">
    <Border CornerRadius="8"
            Background="#F0161B18"
            BorderBrush="#4936D87B"
            BorderThickness="1"
            Padding="11"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ArtworkColumn" Width="74" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="IconColumn" Width="66" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ArtworkFrame"
                    Width="64"
                    Height="64"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    CornerRadius="6"
                    Background="#202824"
                    BorderBrush="#334139"
                    BorderThickness="1">
                <Grid>
                    <Image x:Name="AlbumArt"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock x:Name="AlbumPlaceholder"
                               Text="SP"
                               Foreground="#6F7D74"
                               FontWeight="Bold"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="ActionText"
                           Foreground="#8DE6B1"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="TrackTitle"
                           Grid.Row="1"
                           Foreground="#F7FAF8"
                           FontSize="16"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ArtistText"
                           Grid.Row="2"
                           Foreground="#B9C4BE"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="FooterText"
                           Text="Spotify Избранное"
                           Grid.Row="3"
                           Foreground="#7F8D84"
                           FontSize="10"
                           VerticalAlignment="Bottom" />
            </Grid>

            <Grid x:Name="IconStage"
                  Grid.Column="2"
                  Width="58"
                  Height="58"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Canvas x:Name="FavoriteIconCanvas"
                        Width="54"
                        Height="54"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Path x:Name="DropShape"
                          Data="M 27,8 C 35,19 39,25 39,33 C 39,41 33.5,46 27,46 C 20.5,46 15,41 15,33 C 15,25 19,19 27,8 Z"
                          Fill="#1ED760"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="DropScale"
                                                ScaleX="0.25"
                                                ScaleY="0.25" />
                                <TranslateTransform x:Name="DropTranslate"
                                                    Y="-5" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartFill"
                          Data="M 27,45 C 22,40 9,30 7,19 C 5.5,11 11,6 18,9 C 22,10.5 25,14 27,17 C 29,14 32,10.5 36,9 C 43,6 48.5,11 47,19 C 45,30 32,40 27,45 Z"
                          Fill="#1ED760"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="HeartScale"
                                                ScaleX="0.82"
                                                ScaleY="0.82" />
                                <RotateTransform x:Name="HeartRotate"
                                                 Angle="0" />
                                <TranslateTransform x:Name="HeartTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartOutline"
                          Data="M 27,45 C 22,40 9,30 7,19 C 5.5,11 11,6 18,9 C 22,10.5 25,14 27,17 C 29,14 32,10.5 36,9 C 43,6 48.5,11 47,19 C 45,30 32,40 27,45 Z"
                          Fill="Transparent"
                          Stroke="#D5E7DC"
                          StrokeThickness="3"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Opacity="0" />

                    <Path x:Name="CrackLines"
                          Data="M 27,17 L 23,25 L 29,29 L 24,39 M 35,12 L 31,22 L 36,26"
                          Stroke="#101512"
                          StrokeThickness="2.2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Opacity="0" />

                    <Path x:Name="HeartPieceLeft"
                          Data="M 27,45 C 22,40 9,30 7,19 C 5.5,11 11,6 18,9 C 22,10.5 25,14 27,17 L 24,28 L 27,45 Z"
                          Fill="#8CA896"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="LeftPieceRotate" />
                                <TranslateTransform x:Name="LeftPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartPieceRight"
                          Data="M 27,45 L 24,28 L 27,17 C 29,14 32,10.5 36,9 C 43,6 48.5,11 47,19 C 45,30 32,40 27,45 Z"
                          Fill="#789181"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="RightPieceRotate" />
                                <TranslateTransform x:Name="RightPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartPieceCenter"
                          Data="M 24,28 L 29,29 L 24,39 L 27,45 L 24,28 Z"
                          Fill="#A9BDAF"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="CenterPieceRotate" />
                                <TranslateTransform x:Name="CenterPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>
                </Canvas>

                <TextBlock x:Name="ErrorIconText"
                           Text="!"
                           Foreground="#FFC457"
                           FontSize="48"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Border>
</Window>
