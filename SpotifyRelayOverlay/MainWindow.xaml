<Window x:Class="SpotifyRelayOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spotify Favorite Hotkey"
        Width="420"
        Height="190"
        MinWidth="380"
        MinHeight="170"
        ResizeMode="CanMinimize"
        ShowInTaskbar="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        SourceInitialized="Window_SourceInitialized">
    <Border Background="#111713"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Spotify Favorite Hotkey"
                       Foreground="#F4F8F5"
                       FontSize="18"
                       FontWeight="SemiBold" />

            <StackPanel Grid.Row="1"
                        Margin="0,16,0,0">
                <TextBlock x:Name="HotkeyText"
                           Foreground="#9ECFB1"
                           FontSize="13"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="StatusText"
                           Margin="0,10,0,0"
                           Foreground="#CFE1D5"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Настройки"
                        Width="104"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="SettingsButton_Click" />
                <Button Content="Скрыть"
                        Width="86"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="HideButton_Click" />
                <Button Content="Выход"
                        Width="76"
                        Height="34"
                        Click="ExitButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
