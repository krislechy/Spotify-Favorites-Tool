<Window x:Class="SpotifyRelayOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spotify Relay Overlay"
        Width="360"
        Height="102"
        MinWidth="330"
        MinHeight="92"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        SourceInitialized="Window_SourceInitialized"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border x:Name="Chrome"
            CornerRadius="8"
            Background="#E7101512"
            BorderBrush="#4936D87B"
            BorderThickness="1"
            Padding="8"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="58" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="54" />
            </Grid.ColumnDefinitions>

            <Border Width="52"
                    Height="52"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    CornerRadius="6"
                    Background="#202824"
                    BorderBrush="#334139"
                    BorderThickness="1">
                <Grid>
                    <Image x:Name="AlbumArt"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock x:Name="AlbumPlaceholder"
                               Text="SP"
                               Foreground="#6F7D74"
                               FontWeight="Bold"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="15" />
                    <RowDefinition Height="21" />
                    <RowDefinition Height="17" />
                    <RowDefinition Height="7" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="StatusText"
                           Grid.Row="0"
                           Foreground="#8DE6B1"
                           FontSize="10"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="TrackTitle"
                           Grid.Row="1"
                           Foreground="#F7FAF8"
                           FontSize="13"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ArtistText"
                           Grid.Row="2"
                           Foreground="#B9C4BE"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis" />
                <ProgressBar x:Name="Progress"
                             Grid.Row="3"
                             Height="3"
                             Minimum="0"
                             Maximum="100"
                             Foreground="#1ED760"
                             Background="#2C3530"
                             BorderThickness="0"
                             VerticalAlignment="Center" />
                <DockPanel Grid.Row="4" LastChildFill="False">
                    <TextBlock x:Name="LikedText"
                               Foreground="#D5E7DC"
                               FontSize="10"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Bottom" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right">
                        <Button x:Name="PreviousButton"
                                Style="{StaticResource OverlayButton}"
                                Content="&#x23EE;"
                                Click="PreviousButton_Click"
                                ToolTip="Предыдущий трек" />
                        <Button x:Name="PlayPauseButton"
                                Style="{StaticResource OverlayButton}"
                                Content="&#x25B6;"
                                Click="PlayPauseButton_Click"
                                ToolTip="Пауза / продолжить" />
                        <Button x:Name="NextButton"
                                Style="{StaticResource OverlayButton}"
                                Content="&#x23ED;"
                                Click="NextButton_Click"
                                ToolTip="Следующий трек" />
                    </StackPanel>
                </DockPanel>
            </Grid>

            <Grid Grid.Column="2" HorizontalAlignment="Right">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                </Grid.RowDefinitions>

                <Button x:Name="LikeButton"
                        Grid.Row="0"
                        Style="{StaticResource OverlayButton}"
                        Content="&#x2661;"
                        Click="LikeButton_Click"
                        ToolTip="Лайкнуть текущий трек" />
                <Button Grid.Row="1"
                        Style="{StaticResource OverlayButton}"
                        Content="&#x2699;"
                        FontSize="13"
                        Click="SettingsButton_Click"
                        ToolTip="Настройки" />
                <Button Grid.Row="2"
                        Style="{StaticResource OverlayButton}"
                        Content="x"
                        FontSize="13"
                        Margin="0"
                        Click="CloseButton_Click"
                        ToolTip="Закрыть" />
            </Grid>
        </Grid>
    </Border>
</Window>
