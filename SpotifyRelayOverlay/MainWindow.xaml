<Window x:Class="SpotifyRelayOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spotify Избранное"
        Width="600"
        Height="270"
        MinWidth="430"
        MinHeight="250"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        SourceInitialized="Window_SourceInitialized">
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1ED760" />
                                <Setter Property="Foreground" Value="#0F1511" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleButton" BasedOn="{StaticResource IconButton}" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>

    <Border Margin="8"
            CornerRadius="12"
            Background="#101512"
            BorderBrush="#2A3A31"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.28"
                              Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Margin="10,8,10,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="28"
                        Height="28"
                        CornerRadius="7"
                        Background="#1ED760">
                    <TextBlock Text="♥"
                               Foreground="#0F1511"
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Spotify Избранное"
                               Foreground="#F4F8F5"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Горячая клавиша для текущего трека"
                               Foreground="#7F8D84"
                               FontSize="10" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleButton}"
                            Content="⚙"
                            Click="SettingsButton_Click"
                            ToolTip="Настройки" />
                    <Button Style="{StaticResource TitleButton}"
                            Content="─"
                            Click="MinimizeButton_Click"
                            ToolTip="Свернуть" />
                    <Button Style="{StaticResource TitleButton}"
                            Content="×"
                            Margin="0"
                            Click="CloseToTrayButton_Click"
                            ToolTip="Закрыть в трей" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="12,10,12,12"
                    Padding="16"
                    CornerRadius="10"
                    Background="#141B17"
                    BorderBrush="#25342C"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Одна клавиша для добавления и удаления текущего трека из Избранного"
                                   Foreground="#D7E4DC"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,14,0,0"
                            Padding="12"
                            CornerRadius="8"
                            Background="#18201B"
                            BorderBrush="#28362E"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock x:Name="HotkeyText"
                                       Foreground="#8DE6B1"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="StatusText"
                                       Margin="0,8,0,0"
                                       Foreground="#D7E4DC"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
