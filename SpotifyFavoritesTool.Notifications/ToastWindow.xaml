<Window x:Class="SpotifyFavoritesTool.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="388"
        Height="96"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        KeyboardNavigation.TabNavigation="None"
        KeyboardNavigation.ControlTabNavigation="None"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Border CornerRadius="8"
            Background="#FC161B18"
            BorderBrush="#4936D87B"
            BorderThickness="1"
            Padding="8"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ArtworkColumn" Width="66" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="IconColumn" Width="48" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ArtworkFrame"
                    Width="54"
                    Height="54"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    CornerRadius="6"
                    Background="#202824"
                    BorderBrush="#334139"
                    BorderThickness="1">
                <Grid>
                    <Image x:Name="AlbumArt"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock x:Name="AlbumPlaceholder"
                               Text="SP"
                               Foreground="#6F7D74"
                               FontWeight="Bold"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="18" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="18" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="ActionText"
                               Foreground="#8DE6B1"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel x:Name="PlayingEqualizer"
                                Orientation="Horizontal"
                                Width="22"
                                Height="14"
                                Margin="7,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <StackPanel.Resources>
                            <Style TargetType="Rectangle">
                                <Setter Property="Width" Value="3" />
                                <Setter Property="RadiusX" Value="1.4" />
                                <Setter Property="RadiusY" Value="1.4" />
                                <Setter Property="Fill" Value="#8DE6B1" />
                                <Setter Property="VerticalAlignment" Value="Bottom" />
                                <Setter Property="Margin" Value="0,0,2,0" />
                            </Style>
                        </StackPanel.Resources>
                        <Rectangle Height="5">
                            <Rectangle.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                             From="5"
                                                             To="13"
                                                             Duration="0:0:0.34" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Rectangle.Triggers>
                        </Rectangle>
                        <Rectangle Height="11">
                            <Rectangle.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                             From="11"
                                                             To="4"
                                                             BeginTime="0:0:0.08"
                                                             Duration="0:0:0.42" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Rectangle.Triggers>
                        </Rectangle>
                        <Rectangle Height="7">
                            <Rectangle.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                             From="7"
                                                             To="14"
                                                             BeginTime="0:0:0.14"
                                                             Duration="0:0:0.30" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Rectangle.Triggers>
                        </Rectangle>
                        <Rectangle Height="12" Margin="0">
                            <Rectangle.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                             From="12"
                                                             To="5"
                                                             BeginTime="0:0:0.20"
                                                             Duration="0:0:0.38" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Rectangle.Triggers>
                        </Rectangle>
                    </StackPanel>
                </StackPanel>
                <TextBlock x:Name="TrackTitle"
                           Grid.Row="1"
                           Foreground="#F7FAF8"
                           FontSize="14.5"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ArtistText"
                           Grid.Row="2"
                           Foreground="#B9C4BE"
                           FontSize="11.5"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <Grid x:Name="IconStage"
                  Grid.Column="2"
                  Width="42"
                  Height="48"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Canvas x:Name="FavoriteIconCanvas"
                        Width="40"
                        Height="36"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                    <Canvas.RenderTransform>
                        <ScaleTransform ScaleX="0.72" ScaleY="0.68" />
                    </Canvas.RenderTransform>
                    <Ellipse x:Name="HeartGlow"
                             Canvas.Left="-8"
                             Canvas.Top="-8"
                             Width="70"
                             Height="70"
                             Opacity="0"
                             IsHitTestVisible="False"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#F48DFFB1"
                                              Offset="0" />
                                <GradientStop Color="#C41ED760"
                                              Offset="0.44" />
                                <GradientStop Color="#001ED760"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <BlurEffect Radius="13" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="GlowScale"
                                            ScaleX="0.55"
                                            ScaleY="0.55" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Path x:Name="SparkleTop"
                          Data="M 27,2 L 29.2,8 L 35,10 L 29.2,12 L 27,18 L 24.8,12 L 19,10 L 24.8,8 Z"
                          Fill="#D8FFE6"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="SparkleTopScale"
                                                ScaleX="0.25"
                                                ScaleY="0.25" />
                                <RotateTransform x:Name="SparkleTopRotate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="SparkleLeft"
                          Data="M 8,16 L 9.4,20 L 13.5,21.4 L 9.4,22.8 L 8,27 L 6.6,22.8 L 2.5,21.4 L 6.6,20 Z"
                          Fill="#A7F6C4"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <ScaleTransform x:Name="SparkleLeftScale"
                                            ScaleX="0.25"
                                            ScaleY="0.25" />
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="SparkleRight"
                          Data="M 46,18 L 47.5,22 L 51.5,23.5 L 47.5,25 L 46,29 L 44.5,25 L 40.5,23.5 L 44.5,22 Z"
                          Fill="#E5FFEE"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <ScaleTransform x:Name="SparkleRightScale"
                                            ScaleX="0.25"
                                            ScaleY="0.25" />
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="DropShape"
                          Data="M 27,8 C 35,19 39,25 39,33 C 39,41 33.5,46 27,46 C 20.5,46 15,41 15,33 C 15,25 19,19 27,8 Z"
                          Fill="#1ED760"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="DropScale"
                                                ScaleX="0.25"
                                                ScaleY="0.25" />
                                <TranslateTransform x:Name="DropTranslate"
                                                    Y="-5" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartFill"
                          Data="M 27,47 C 22,42 7,31.5 5.8,19 C 4.8,9 12.5,4 19.4,8.5 C 23.3,11 25.7,14.6 27,17.8 C 28.3,14.6 30.7,11 34.6,8.5 C 41.5,4 49.2,9 48.2,19 C 47,31.5 32,42 27,47 Z"
                          Fill="#18B653"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="1"
                                              Direction="270"
                                              Opacity="0.62"
                                              Color="#05150C" />
                        </Path.Effect>
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="HeartScale"
                                                ScaleX="0.82"
                                                ScaleY="0.82" />
                                <RotateTransform x:Name="HeartRotate"
                                                 Angle="0" />
                                <TranslateTransform x:Name="HeartTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartOutline"
                          Data="M 27,47 C 22,42 7,31.5 5.8,19 C 4.8,9 12.5,4 19.4,8.5 C 23.3,11 25.7,14.6 27,17.8 C 28.3,14.6 30.7,11 34.6,8.5 C 41.5,4 49.2,9 48.2,19 C 47,31.5 32,42 27,47 Z"
                          Fill="Transparent"
                          Stroke="#D5E7DC"
                          StrokeThickness="3"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Opacity="0">
                        <Path.Effect>
                            <DropShadowEffect BlurRadius="8"
                                              ShadowDepth="0"
                                              Opacity="0.42"
                                              Color="#05150C" />
                        </Path.Effect>
                    </Path>

                    <Path x:Name="HeartTexture"
                          Data="M 27,47 C 22,42 7,31.5 5.8,19 C 4.8,9 12.5,4 19.4,8.5 C 23.3,11 25.7,14.6 27,17.8 C 28.3,14.6 30.7,11 34.6,8.5 C 41.5,4 49.2,9 48.2,19 C 47,31.5 32,42 27,47 Z"
                          Opacity="0"
                          IsHitTestVisible="False">
                        <Path.Fill>
                            <DrawingBrush Viewport="0,0,7,7"
                                          ViewportUnits="Absolute"
                                          TileMode="Tile"
                                          Opacity="0.24">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="#0D7A39"
                                                     Geometry="M 0,6 L 6,0 L 7,1 L 1,7 Z" />
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Path.Fill>
                    </Path>

                    <Path x:Name="CrackLines"
                          Data="M 27,17 L 23,25 L 29,29 L 24,39 M 35,12 L 31,22 L 36,26"
                          Stroke="#101512"
                          StrokeThickness="2.2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Opacity="0" />

                    <Path x:Name="HeartPieceLeft"
                          Data="M 27,47 C 22,42 7,31.5 5.8,19 C 4.8,9 12.5,4 19.4,8.5 C 23.3,11 25.7,14.6 27,17.8 L 24,29 L 27,47 Z"
                          Fill="#8CA896"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="LeftPieceRotate" />
                                <TranslateTransform x:Name="LeftPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartPieceRight"
                          Data="M 27,47 L 24,29 L 27,17.8 C 28.3,14.6 30.7,11 34.6,8.5 C 41.5,4 49.2,9 48.2,19 C 47,31.5 32,42 27,47 Z"
                          Fill="#789181"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="RightPieceRotate" />
                                <TranslateTransform x:Name="RightPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <Path x:Name="HeartPieceCenter"
                          Data="M 24,29 L 29,30 L 24,40 L 27,47 L 24,29 Z"
                          Fill="#A9BDAF"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="CenterPieceRotate" />
                                <TranslateTransform x:Name="CenterPieceTranslate" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                </Canvas>

                <TextBlock x:Name="ErrorIconText"
                           Text="!"
                           Foreground="#FFC457"
                           FontSize="48"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Border>
</Window>
