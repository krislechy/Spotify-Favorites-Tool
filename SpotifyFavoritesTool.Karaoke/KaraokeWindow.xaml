<Window x:Class="SpotifyFavoritesTool.KaraokeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:SpotifyFavoritesTool.UI;assembly=SpotifyFavoritesTool.UI"
        Title="Karaoke"
        Width="560"
        Height="480"
        MinWidth="480"
        MinHeight="380"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        KeyboardNavigation.TabNavigation="None"
        KeyboardNavigation.ControlTabNavigation="None"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="KaraokeIconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#F4F8F5" />
            <Setter Property="Background" Value="#202A24" />
            <Setter Property="BorderBrush" Value="#3D4B42" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="ui:RippleEffectBehavior.IsEnabled" Value="True" />
            <Setter Property="ui:RippleEffectBehavior.RippleBrush" Value="#1ED760" />
            <Setter Property="ui:RippleEffectBehavior.PressedOpacity" Value="0.24" />
            <Setter Property="ui:RippleEffectBehavior.DurationMilliseconds" Value="420" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" />
                            <Canvas x:Name="RippleHost"
                                    ClipToBounds="True"
                                    IsHitTestVisible="False">
                                <Canvas.OpacityMask>
                                    <VisualBrush Visual="{Binding ElementName=Root}" />
                                </Canvas.OpacityMask>
                            </Canvas>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2B3A32" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4E6357" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#203A29" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1ED760" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ui:LiquidHoverBorder Margin="8"
                          CornerRadius="14"
                          BaseColor="#101512"
                          SurfaceOpacity="1"
                          BorderBrush="#365142"
                          BorderThickness="1"
                          SnapsToDevicePixels="True">
        <ui:LiquidHoverBorder.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="0"
                              Opacity="0.32"
                              Color="#000000" />
        </ui:LiquidHoverBorder.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Margin="12,8,12,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="28"
                        Height="28"
                        CornerRadius="7"
                        Background="#1ED760">
                    <Canvas Width="16"
                            Height="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Path Data="M 8,2 C 6.4,2 5.4,3.2 5.4,4.8 L 5.4,8.2 C 5.4,9.8 6.4,11 8,11 C 9.6,11 10.6,9.8 10.6,8.2 L 10.6,4.8 C 10.6,3.2 9.6,2 8,2 Z"
                              Fill="#0F1511" />
                        <Path Data="M 3.5,7.8 C 3.5,10.3 5.3,12.2 8,12.2 C 10.7,12.2 12.5,10.3 12.5,7.8 M 8,12.2 L 8,15 M 5.5,15 L 10.5,15"
                              Stroke="#0F1511"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Canvas>
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Karaoke"
                               Foreground="#F4F8F5"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="WindowStatusText"
                               Text="Экспериментальный режим"
                               Foreground="#7F8D84"
                               FontSize="10" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource KaraokeIconButton}"
                            Margin="0,0,8,0"
                            Click="RefreshButton_Click"
                            ToolTip="Обновить текущий трек">
                        <Canvas Width="16"
                                Height="16"
                                IsHitTestVisible="False">
                            <Path Data="M 13,5 A 5,5 0 1 0 14,9 M 13,5 L 13,2 L 10,2 M 3,11 A 5,5 0 1 0 2,7 M 3,11 L 3,14 L 6,14"
                                  Stroke="#F4F8F5"
                                  StrokeThickness="1.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Canvas>
                    </Button>
                    <Button Style="{StaticResource KaraokeIconButton}"
                            Margin="0"
                            Content="×"
                            FontSize="16"
                            Click="CloseButton_Click"
                            ToolTip="Закрыть" />
                </StackPanel>
            </Grid>

            <ui:LiquidHoverBorder Grid.Row="1"
                                  Margin="12,10,12,12"
                                  Padding="16"
                                  CornerRadius="12"
                                  BaseColor="#141B17"
                                  IsLiquidEnabled="False"
                                  SurfaceOpacity="0.20"
                                  BorderBrush="#25342C"
                                  BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="64"
                                Height="64"
                                CornerRadius="9"
                                Background="#202824"
                                BorderBrush="#334139"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.OpacityMask>
                                    <VisualBrush>
                                        <VisualBrush.Visual>
                                            <Border Width="64"
                                                    Height="64"
                                                    Background="Black"
                                                    CornerRadius="9" />
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Grid.OpacityMask>
                                <Image x:Name="AlbumArt"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock x:Name="AlbumPlaceholder"
                                           Text="SP"
                                           Foreground="#6F7D74"
                                           FontWeight="Bold"
                                           FontSize="17"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="TrackTitle"
                                       Text="Ничего не играет"
                                       Foreground="#F7FAF8"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="ArtistText"
                                       Margin="0,4,0,0"
                                       Foreground="#B9C4BE"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="SyncStatusText"
                                       Margin="0,8,0,0"
                                       Foreground="#8DE6B1"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,16,0,0">
                        <ListBox x:Name="LyricsList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#D7E4DC"
                                 IsTabStop="False"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,6" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="IsTabStop" Value="False" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="8">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="LineRoot"
                                            Padding="10,7"
                                            CornerRadius="8"
                                            Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="46" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TimeText}"
                                                       Foreground="#6F7D74"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       VerticalAlignment="Center" />
                                            <TextBlock x:Name="LineText"
                                                       Grid.Column="1"
                                                       Text="{Binding Text}"
                                                       Foreground="#B9C4BE"
                                                       FontSize="14"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter TargetName="LineRoot" Property="Background" Value="#3020362B" />
                                            <Setter TargetName="LineText" Property="Foreground" Value="#F7FAF8" />
                                            <Setter TargetName="LineText" Property="FontSize" Value="18" />
                                            <Setter TargetName="LineText" Property="FontWeight" Value="Bold" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock x:Name="PlainLyricsText"
                                   Visibility="Collapsed"
                                   Foreground="#D7E4DC"
                                   FontSize="14"
                                   LineHeight="22"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Grid>
            </ui:LiquidHoverBorder>
        </Grid>
    </ui:LiquidHoverBorder>
</Window>
